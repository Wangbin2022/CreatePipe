<Window x:Class="CreatePipe.Obselete.Universal369Buttons"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.Obselete"
        xmlns:converters="clr-namespace:CreatePipe"
        Title="文本暂存器" 
        Height="350" Width="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        Topmost="{Binding IsTopmost}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <!--<Window.Resources>
        --><!-- 按钮数量转换器 --><!--
        <converters:ButtonCountToVisibilityConverter x:Key="ButtonCountToVisibilityConverter"/>

        --><!-- 按钮基础样式 --><!--
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property = "Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>-->

    <Border Background="#F0F0F0"
            BorderBrush="#AAAAAA"
            BorderThickness="1"
            CornerRadius="8">

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="25"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Background="#E0E0E0" Margin="-8,-8,-8,0" Height="35">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="文本暂存器" 
                          VerticalAlignment="Center" 
                          Margin="10,0,0,0"
                          FontWeight="Bold"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="3-6-9" 
                            ToolTip="切换按钮数量"
                            Command="{Binding ToggleButtonCountCommand}"/>
                    <!--<Button Content="{Binding IsTopmost, Converter={converters:BooleanToCharConverter}}" 
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="{Binding IsTopmost, Converter={converters:BooleanToToolTipConverter}}"
                            Command="{Binding ToggleTopmostCommand}"/>-->
                </StackPanel>

                <Button Grid.Column="2" 
                        Content="✕" 
                        ToolTip="关闭"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- 按钮区域 - 使用UniformGrid实现网格布局 -->
            <ItemsControl Grid.Row="1" 
                         ItemsSource="{Binding ClipboardItems}"
                         Margin="0,10,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" Rows="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ItemBorder"
                                Background="White" 
                                BorderBrush="#DDDDDD" 
                                BorderThickness="1" 
                                CornerRadius="5"
                                Margin="3">

                            <!-- 根据按钮数量控制显示/隐藏 -->
                            <!--<Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.VisibleButtonCount}" Value="3">
                                            <Setter Property="Visibility" Value="{Binding RelativeSource={RelativeSource Self}, Converter={StaticResource ButtonCountToVisibilityConverter}, ConverterParameter=3}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.VisibleButtonCount}" Value="6">
                                            <Setter Property="Visibility" Value="{Binding RelativeSource={RelativeSource Self}, Converter={StaticResource ButtonCountToVisibilityConverter}, ConverterParameter=6}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>-->

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 主按钮：点击保存剪贴板内容 -->
                                <Button Grid.Row="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.SaveToButtonCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayText}" 
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   Margin="5"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}"
                                                   FontSize="9"
                                                   Foreground="#999999"
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- 操作按钮行 -->
                                <StackPanel Grid.Row="1" 
                                            Orientation="Horizontal" 
                                            HorizontalAlignment="Center"
                                            Margin="0,2,0,2">
                                    <!-- 复制按钮 -->
                                    <Button Content="📋" 
                                            Width="22" Height="22"
                                            FontSize="12"
                                            Margin="1"
                                            ToolTip="复制到剪贴板"
                                            Command="{Binding DataContext.CopyFromButtonCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Opacity" Value="0.3"/>
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasContent}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- 清空按钮 -->
                                    <Button Content="🗑️" 
                                            Width="22" Height="22"
                                            FontSize="12"
                                            Margin="1"
                                            ToolTip="清空"
                                            Command="{Binding DataContext.ClearButtonCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Opacity" Value="0.3"/>
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasContent}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 状态栏 -->
            <Border Grid.Row="2" 
                    Background="#E0E0E0" 
                    Margin="-8,0,-8,-8" 
                    Height="25"
                    CornerRadius="0,0,8,8">
                <TextBlock Text="{Binding StatusMessage}" 
                          VerticalAlignment="Center" 
                          Margin="10,0,0,0"
                          Foreground="#666666"
                          FontSize="11"/>
            </Border>
        </Grid>
    </Border>
</Window>
