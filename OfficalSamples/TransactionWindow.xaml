<Window x:Class="CreatePipe.OfficalSamples.TransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
      Title="Revit事务管理演示工具"         Height="650" Width="950"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="CanResize"     MinHeight="600" MinWidth="850"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <!-- 转换器 -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <!-- 事务状态颜色样式 -->
        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Background" Value="#FFE0E0E0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#FF2C3E50" Padding="10" Margin="-10,-10,-10,5" 
                CornerRadius="0,0,5,5">
            <StackPanel>
                <TextBlock Text="Revit事务管理演示工具" FontSize="16" 
                           FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="演示 Transaction 和 TransactionGroup 的使用" FontSize="11" 
                           Foreground="#FFBDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：操作面板 -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,5,5,0">
                    <!-- 事务组操作 -->
                    <GroupBox Header="📁 事务组 (Transaction Group)" Margin="0,0,0,10">
                        <StackPanel Margin="5">
                            <Button Content="▶ 开始事务组" 
                                    Command="{Binding StartTransactionGroupCommand}"
                                    Background="#FF007ACC" Foreground="White"
                                    Margin="0,0,0,5" Height="32"/>
                            <Button Content="💾 提交事务组" 
                                    Command="{Binding CommitTransactionGroupCommand}"
                                    IsEnabled="{Binding IsTransactionGroupActive}"
                                    Margin="0,0,0,5" Height="32"/>
                            <Button Content="↺ 回滚事务组" 
                                    Command="{Binding RollbackTransactionGroupCommand}"
                                    IsEnabled="{Binding IsTransactionGroupActive}"
                                    Background="#FFCC0000" Foreground="White"
                                    Height="32"/>
                            <Border Style="{StaticResource StatusBadgeStyle}" Margin="0,5,0,0">
                                <TextBlock Text="{Binding TransactionGroupStatus, FallbackValue=未开始}" 
                                           FontSize="11" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <!-- 事务操作 -->
                    <GroupBox Header="📄 事务 (Transaction)" Margin="0,0,0,10">
                        <StackPanel Margin="5">
                            <Button Content="▶ 开始事务" 
                                    Command="{Binding StartTransactionCommand}"
                                    Background="#FF007ACC" Foreground="White"
                                    Margin="0,0,0,5" Height="32"/>
                            <Button Content="💾 提交事务" 
                                    Command="{Binding CommitTransactionCommand}"
                                    IsEnabled="{Binding IsTransactionActive}"
                                    Margin="0,0,0,5" Height="32"/>
                            <Button Content="↺ 回滚事务" 
                                    Command="{Binding RollbackTransactionCommand}"
                                    IsEnabled="{Binding IsTransactionActive}"
                                    Background="#FFCC0000" Foreground="White"
                                    Height="32"/>
                            <Border Style="{StaticResource StatusBadgeStyle}" Margin="0,5,0,0">
                                <TextBlock Text="{Binding TransactionStatus, FallbackValue=未开始}" 
                                           FontSize="11" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <!-- 墙操作 -->
                    <GroupBox Header="🧱 墙操作" Margin="0,0,0,10">
                        <StackPanel Margin="5">
                            <Button Content="➕ 创建墙" 
                                    Command="{Binding CreateWallCommand}"
                                    Margin="0,0,0,5" Height="32"/>

                            <GroupBox Header="移动墙" Margin="0,5,0,5">
                                <Grid Margin="5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MoveX}" Margin="0,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Y:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MoveY}" Margin="0,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Z:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MoveZ}" Margin="0,2"/>
                                </Grid>
                            </GroupBox>

                            <Button Content="📐 移动墙" 
                                    Command="{Binding MoveWallCommand}"
                                    IsEnabled="{Binding SelectedWall}"
                                    Margin="0,5,0,5" Height="32"/>

                            <Button Content="🗑️ 删除墙" 
                                    Command="{Binding DeleteWallCommand}"
                                    IsEnabled="{Binding SelectedWall}"
                                    Background="#FFFF6666" Foreground="White"
                                    Height="32"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 选中的墙列表 -->
                    <GroupBox Header="📋 选中的墙" Margin="0,0,0,10">
                        <StackPanel>
                            <Button Content="🔄 刷新" Command="{Binding RefreshWallsCommand}" 
                                    Height="28" Margin="5,0,5,5"/>
                            <ListBox ItemsSource="{Binding SelectedWalls}" 
                                     SelectedItem="{Binding SelectedWall}"
                                     DisplayMemberPath="DisplayName"
                                     Height="150"
                                     BorderThickness="0">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="5,3"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FFE8F0FE"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <!-- 分隔线 -->
            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch" 
                          Background="#FFD9D9D9"/>

            <!-- 右侧：事务结构和日志 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <!-- 事务结构树 -->
                <GroupBox Header="🌳 事务结构" Grid.Row="0">
                    <TreeView ItemsSource="{Binding RootNode.Children}" 
                              SelectedItemChanged="TreeView_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁 " FontSize="12"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" (" Margin="5,0,0,0"/>
                                    <TextBlock Text="{Binding Status}" Foreground="#FF888888"/>
                                    <TextBlock Text=")"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </GroupBox>

                <!-- 分隔线 -->
                <GridSplitter Grid.Row="1" Height="3" HorizontalAlignment="Stretch" 
                              Background="#FFD9D9D9"/>

                <!-- 日志区域 -->
                <GroupBox Header="📝 事务日志" Grid.Row="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Content="清除日志" Command="{Binding ClearLogCommand}"
                                HorizontalAlignment="Right" Width="80" Height="25" Margin="0,0,0,5"/>

                        <ListBox Grid.Row="1" 
                                 ItemsSource="{Binding LogEntries}"
                                 VirtualizingPanel.ScrollUnit="Pixel">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayMessage}" 
                                               FontSize="11"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Margin="0,5,0,0" Background="#FFF0F0F0" Height="30">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="Green" Margin="0,0,8,0"/>
                    <TextBlock Text="就绪" FontSize="11"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
