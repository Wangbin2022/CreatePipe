<Window x:Class="CreatePipe.OfficalSamples.DatumPropagationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
 Title="基准线范围传播工具" Height="550" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="450" MinWidth="500"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <local:CountToBooleanConverter x:Key="CountToBooleanConverter"/>
        <local:ViewTypeToBrushConverter x:Key="ViewTypeToBrushConverter"/>
        <local:SuccessToBrushConverter x:Key="SuccessToBrushConverter"/>
        <local:SuccessToForegroundConverter x:Key="SuccessToForegroundConverter"/>
        
        <!-- 视图类型颜色转换器 -->
        <SolidColorBrush x:Key="FloorPlanBrush" Color="#3498DB"/>
        <SolidColorBrush x:Key="ElevationBrush" Color="#2ECC71"/>
        <SolidColorBrush x:Key="SectionBrush" Color="#E74C3C"/>
        <SolidColorBrush x:Key="OtherViewBrush" Color="#95A5A6"/>

        <Style x:Key="ViewListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#E8F4FD"/>
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- 标题 -->
            <TextBlock Grid.Row="0" Text="基准线范围传播" FontSize="16" FontWeight="Bold" 
                       Margin="0,0,0,10" HorizontalAlignment="Center"/>
            <!-- 说明 -->
            <TextBlock Grid.Row="1" Text="将当前视图中选中基准线的范围设置应用到其他视图" 
                       FontSize="12" Foreground="Gray" TextWrapping="Wrap"
                       Margin="0,0,0,15" HorizontalAlignment="Center"/>
            <!-- 基准线信息卡片 -->
            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="5" 
                    BorderBrush="#DEE2E6" BorderThickness="1" Padding="12" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="📌" FontSize="18" Margin="0,0,10,0"/>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="当前选中的基准线" FontSize="11" Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedDatum.DisplayName, FallbackValue=未选中}" 
                                   FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="刷新" Width="60" Height="28"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
                </Grid>
            </Border>
            <!-- 视图列表区域 -->
            <GroupBox Grid.Row="3" Header="可传播的目标视图" Margin="0,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- 操作栏 -->
                    <Border Grid.Row="0" Background="#F8F9FA" Padding="8,5" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <CheckBox Content="全选" IsChecked="{Binding SelectAllState}"
                                      IsEnabled="{Binding PropagationViews.Count, Converter={StaticResource CountToBooleanConverter}}"/>
                            <Button Command="{Binding SelectAllCommand}" 
                                    Content="全选" Width="50" Margin="10,0,5,0"/>
                            <Button Command="{Binding SelectNoneCommand}" 
                                    Content="清空" Width="50"/>
                            <TextBlock Text="| 已选择" Margin="15,0,0,0"/>
                            <TextBlock Text="{Binding SelectedCount}" FontWeight="Bold" Margin="5,0"/>
                            <TextBlock Text="个视图"/>
                        </StackPanel>
                    </Border>
                    <!-- 视图列表 -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding PropagationViews}"
                             ItemContainerStyle="{StaticResource ViewListItemStyle}"
                             SelectionMode="Extended"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>

                                    <Border Grid.Column="1" CornerRadius="3" Padding="5,3"
                                            Background="{Binding ViewType, Converter={StaticResource ViewTypeToBrushConverter}}"
                                            Opacity="0.1">
                                        <TextBlock Text="{Binding DisplayName}" 
                                                   Foreground="{Binding ViewType, Converter={StaticResource ViewTypeToBrushConverter}}"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <!-- 空状态提示 -->
                    <TextBlock Grid.Row="1" Text="暂无可用视图"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="Gray" Visibility="{Binding PropagationViews.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                </Grid>
            </GroupBox>
            <!-- 结果消息 -->
            <Border Grid.Row="4" Background="{Binding LastResult.Success, Converter={StaticResource SuccessToBrushConverter}}"
                    CornerRadius="3" Padding="8,5" Margin="0,10"
                    Visibility="{Binding LastResult, Converter={StaticResource NullToVisibilityConverter}}">
                <TextBlock Text="{Binding LastResult.Message}" 
                           TextWrapping="Wrap" FontSize="11"
                           Foreground="{Binding LastResult.Success, Converter={StaticResource SuccessToForegroundConverter}}"/>
            </Border>
            <!-- 按钮区域 -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                <Button Command="{Binding PropagateCommand}" 
                        Content="传播范围" Width="100" Height="32"
                        IsEnabled="{Binding CanPropagate}"
                        Background="#007ACC" Foreground="White"
                        Margin="0,0,10,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#007ACC"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#CCC"/>
                                    <Setter Property="Foreground" Value="Gray"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Command="{Binding CancelCommand}" Content="关闭" Width="80" Height="32"/>
            </StackPanel>
            <!-- 加载进度提示 -->
            <Border Grid.RowSpan="6" Background="#80FFFFFF" 
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                    <TextBlock Text="正在加载视图列表..." Margin="0,10,0,0" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <!-- 传播进度提示 -->
            <Border Grid.RowSpan="6" Background="#80FFFFFF" 
                    Visibility="{Binding IsPropagating, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
