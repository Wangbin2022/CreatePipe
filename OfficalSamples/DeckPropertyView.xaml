<Window x:Class="CreatePipe.OfficalSamples.DeckPropertyView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
  Title="楼板/压型钢板属性查看器" Height="650" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="700"
         xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <local:SuccessToBrushConverter x:Key="SuccessToBrushConverter"/>
        <local:SuccessToForegroundConverter x:Key="SuccessToForegroundConverter"/>
        <local:LayerTypeToBrushConverter x:Key="LayerTypeToBrushConverter"/>
        <local:CountToBooleanConverter x:Key="CountToBooleanConverter"/>
        <local:SuccessToIconConverter x:Key="SuccessToIconConverter"/>
        
        <!-- 层类型颜色转换器 -->
        <SolidColorBrush x:Key="DeckLayerBrush" Color="#E8A735"/>
        <SolidColorBrush x:Key="StructureLayerBrush" Color="#3498DB"/>
        <SolidColorBrush x:Key="ThermalLayerBrush" Color="#E74C3C"/>
        <SolidColorBrush x:Key="FinishLayerBrush" Color="#2ECC71"/>

        <Style x:Key="DeckParameterStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="20,2,0,2"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 标题栏 -->
            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                <TextBlock Text="楼板/压型钢板属性分析" FontSize="16" FontWeight="Bold" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="分析选中楼板的复合结构，识别并显示压型钢板参数" 
                           FontSize="12" Foreground="Gray" TextWrapping="Wrap"
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- 左侧：楼板列表 -->
            <GroupBox Grid.Row="1" Grid.Column="0" Header="选中的楼板" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F8F9FA" Padding="5" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="共" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding FloorCount}" FontWeight="Bold" Margin="3,0"/>
                            <TextBlock Text="个楼板"/>
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Floors}" 
                             SelectedItem="{Binding SelectedFloor}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="8,5" Margin="2">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayHeader}" 
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Layers.Count, StringFormat='结构层数: {0}'}"
                                                   FontSize="11" Foreground="Gray"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>

            <!-- 右侧：复合结构详情 -->
            <GroupBox Grid.Row="1" Grid.Column="1" Header="复合结构详情" Margin="5,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel Margin="5">
                        <!-- 楼板信息 -->
                        <Border Background="#F0F4F8" CornerRadius="5" Padding="8" Margin="0,0,0,10">
                            <TextBlock Text="{Binding SelectedFloor.DisplayHeader, FallbackValue=请从左侧选择楼板}" 
                                       FontWeight="Bold" FontSize="13"/>
                        </Border>

                        <!-- 层列表 -->
                        <ItemsControl ItemsSource="{Binding SelectedFloor.Layers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Margin="0,3" Padding="5"
                                            Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1">
                                        <StackPanel>
                                            <!-- 层标题 -->
                                            <Border Background="{Binding LayerType, Converter={StaticResource LayerTypeToBrushConverter}}"
                                                    CornerRadius="2" Opacity="0.15" Height="4"/>

                                            <Grid Margin="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="层类型:" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LayerType}"/>

                                                <TextBlock Grid.Column="0" Text="材料:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding MaterialName}" Margin="0,5,0,0"/>

                                                <TextBlock Grid.Column="0" Text="厚度:" FontWeight="SemiBold" Margin="0,5,0,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Thickness, StringFormat=0:F2 mm}" 
                                                           Margin="0,5,0,0"/>
                                            </Grid>
                                            <!-- 压型钢板特殊参数 -->
                                            <!--<DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Path=.}" Value="{x:Type DataTemplate}">                                      
                                                </DataTrigger>
                                            </DataTemplate.Triggers>-->
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 无选中提示 -->
                        <TextBlock Text="未选中楼板" 
                                   HorizontalAlignment="Center" Foreground="Gray"
                                   Visibility="{Binding HasSelectedFloor, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>

            <!-- 分析结果摘要 -->
            <Border Grid.Row="2" Grid.ColumnSpan="2" 
                    Background="{Binding AnalysisResult.Success, Converter={StaticResource SuccessToBrushConverter}}"
                    CornerRadius="5" Padding="10" Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding AnalysisResult.Success, Converter={StaticResource SuccessToIconConverter}}"
                               FontSize="18" Margin="0,0,10,0"/>

                    <TextBlock Grid.Column="1" Text="{Binding AnalysisResult.Message}" 
                               TextWrapping="Wrap" FontSize="11"
                               Foreground="{Binding AnalysisResult.Success, Converter={StaticResource SuccessToForegroundConverter}}"/>

                    <Button Grid.Column="2" Command="{Binding ExportCommand}" 
                            Content="📋 复制报告" Width="90" Height="28"
                            IsEnabled="{Binding FloorCount, Converter={StaticResource CountToBooleanConverter}}"/>
                </Grid>
            </Border>

            <!-- 按钮栏 -->
            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" 
                        Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Command="{Binding RefreshCommand}" 
                        Content="刷新分析" Width="90" Height="30"
                        Margin="0,0,10,0"
                        Background="#007ACC" Foreground="White"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
                <Button Command="{Binding CancelCommand}" Content="关闭" Width="80" Height="30"/>
            </StackPanel>

            <!-- 加载进度 -->
            <Border Grid.RowSpan="4" Grid.ColumnSpan="2" Background="#80FFFFFF" 
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="250" Height="20"/>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
