<Window x:Class="CreatePipe.OfficalSamples.SlabPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
   Title="楼板详细属性分析"  Height="650" Width="850"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="CanResize" MinHeight="600"  MinWidth="750"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- 标题样式 -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- 信息卡片样式 -->
        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF8F9FA"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- 数据网格样式 -->
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF5F5F5"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#FF2C3E50" Padding="10" Margin="-10,-10,-10,5" 
                CornerRadius="0,0,5,5">
            <StackPanel>
                <TextBlock Text="楼板详细属性分析" FontSize="16" 
                           FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="查看楼板的结构层详细信息，包括材料、厚度和弹性模量" FontSize="11" 
                           Foreground="#FFBDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 基本信息卡片 -->
        <Border Grid.Row="1" Style="{StaticResource InfoCardStyle}" Margin="0,10,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：基本信息 -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="📋 基本信息" FontWeight="SemiBold" 
                               Foreground="#FF007ACC" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="标高:" Foreground="#FF666666"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SlabProperties.LevelName, FallbackValue=--}" 
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="类型名称:" Foreground="#FF666666" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SlabProperties.TypeName, FallbackValue=--}" 
                                   FontWeight="SemiBold" Margin="0,5,0,0" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="跨度方向:" Foreground="#FF666666" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SlabProperties.SpanDirectionDisplay, FallbackValue=--}" 
                                   FontWeight="SemiBold" Margin="0,5,0,0"/>
                    </Grid>
                </StackPanel>

                <!-- 分隔线 -->
                <Border Grid.Row="0" Grid.Column="1" Width="1" Background="#FFE0E0E0" Margin="10,5"/>

                <!-- 右侧：统计信息 -->
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="20,0,0,0">
                    <TextBlock Text="📊 统计信息" FontWeight="SemiBold" 
                               Foreground="#FF007ACC" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="结构层数:" Foreground="#FF666666"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SlabProperties.LayerCount, FallbackValue=--}" 
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="总厚度:" Foreground="#FF666666" Margin="0,5,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SlabProperties.TotalThicknessDisplay, FallbackValue=--}" 
                                   FontWeight="SemiBold" Margin="0,5,0,0"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 结构层详情表格 -->
        <GroupBox Grid.Row="2" Header="🏗️ 结构层详细信息" Margin="0,5,0,5">
            <DataGrid ItemsSource="{Binding SlabProperties.Layers}" 
                      SelectedItem="{Binding SelectedLayer}"
                      IsReadOnly="True"
                      SelectionMode="Single">

                <DataGrid.Columns>
                    <!-- 序号 -->
                    <DataGridTextColumn Header="序号" Width="60" 
                                        Binding="{Binding LayerIndex}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 材料名称 -->
                    <DataGridTextColumn Header="材料名称" Width="150" 
                                        Binding="{Binding MaterialName}"/>

                    <!-- 厚度 -->
                    <DataGridTextColumn Header="厚度" Width="120" 
                                        Binding="{Binding ThicknessDisplay}"/>

                    <!-- 弹性模量 X -->
                    <DataGridTextColumn Header="弹性模量 X (MPa)" Width="130" 
                                        Binding="{Binding YoungModulusXDisplay}"/>

                    <!-- 弹性模量 Y -->
                    <DataGridTextColumn Header="弹性模量 Y (MPa)" Width="130" 
                                        Binding="{Binding YoungModulusYDisplay}"/>

                    <!-- 弹性模量 Z -->
                    <DataGridTextColumn Header="弹性模量 Z (MPa)" Width="130" 
                                        Binding="{Binding YoungModulusZDisplay}"/>
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FFE8F0FE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </GroupBox>

        <!-- 底部按钮栏 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="🔄 刷新" Command="{Binding RefreshCommand}"
                    Width="80" Height="30" Margin="0,0,10,0"/>
            <Button Content="📄 导出" Command="{Binding ExportCommand}"
                    Width="80" Height="30" Margin="0,0,10,0"/>
            <Button Content="✗ 关闭" IsCancel="True"
                    Width="80" Height="30"/>
        </StackPanel>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="3" VerticalAlignment="Bottom" 
                   Background="#FFF0F0F0" Height="30"
                   Margin="-10,0,-10,-10">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" 
                               Foreground="#FF333333"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="💡 弹性模量单位: MPa (兆帕)" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 加载遮罩 -->
        <Border Grid.RowSpan="4" Background="#CCFFFFFF" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="White" Padding="30,20" CornerRadius="8" >
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="15"
                                     Foreground="#FF007ACC"/>
                        <TextBlock Text="分析中..." Margin="0,10,0,0" 
                                   HorizontalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
