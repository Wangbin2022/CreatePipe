<Window x:Class="CreatePipe.OfficalSamples.GenerateFloorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
   Title="生成楼板" Height="350" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：预览区域 -->
        <GroupBox Grid.Column="0" Header="轮廓预览" Margin="0,0,10,0">
            <Border Background="Black" BorderBrush="DarkGray" BorderThickness="1">
                <Image Source="{Binding PreviewImage}" 
                       Stretch="None" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
            </Border>
        </GroupBox>

        <!-- 右侧：参数设置区域 -->
        <StackPanel Grid.Column="2" Margin="10,0,0,0">
            <GroupBox Header="楼板参数">
                <StackPanel Margin="5">
                    <TextBlock Text="楼板类型:" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Data.FloorTypeNames}"
                              SelectedItem="{Binding SelectedFloorType}"
                              IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="所在标高:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Data.Level.Name, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,10"/>

                    <CheckBox Content="结构楼板" 
                              IsChecked="{Binding Data.IsStructural}"
                              IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"
                              Margin="0,0,0,10"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="操作">
                <StackPanel Margin="5">
                    <Button Content="刷新轮廓" 
                            Width="100" Height="30" Margin="0,0,0,10"
                            Command="{Binding RefreshCommand}"
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>

                    <Button Content="生成楼板" 
                            Width="100" Height="30"
                            Command="{Binding GenerateCommand}"
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"
                            Background="Green" Foreground="White"/>
                </StackPanel>
            </GroupBox>

            <!-- 状态栏 -->
            <StatusBar Margin="0,10,0,0">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="Blue" TextWrapping="Wrap"/>
                </StatusBarItem>
            </StatusBar>
        </StackPanel>
    </Grid>
</Window>
