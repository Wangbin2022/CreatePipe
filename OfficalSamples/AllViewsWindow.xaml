<Window x:Class="CreatePipe.OfficalSamples.AllViewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
     Title="All Views" Height="450" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧视图树 -->
        <GroupBox Header="All Views" Grid.Column="0">
            <TreeView ItemsSource="{Binding ViewTreeNodes}">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <CheckBox IsChecked="{Binding IsChecked}" Content="{Binding ViewName}"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </GroupBox>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"/>

        <!-- 右侧设置区域 -->
        <GroupBox Header="Generate Sheet" Grid.Column="2">
            <StackPanel Margin="10">
                <Label Content="Title Blocks"/>
                <ComboBox ItemsSource="{Binding TitleBlocks}" 
                          SelectedItem="{Binding SelectedTitleBlock}"
                          Margin="0,0,0,10"/>

                <Label Content="Sheet Name"/>
                <TextBox Text="{Binding SheetName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="OK" Command="{Binding OKCommand}" Width="75" Margin="0,0,5,0" Click="Button_Click"/>
                    <Button Content="Cancel" IsCancel="True" Width="75"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
