<Window x:Class="CreatePipe.OfficalSamples.FloorLayerFunctionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
        Title="楼板结构层功能分析"   Height="550"   Width="650"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="CanResize"   MinHeight="500"  MinWidth="600"
         xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- 列表项容器样式 -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFE8F0FE"/>
                    <Setter Property="BorderBrush" Value="#FF007ACC"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 数据模板：结构层列表项 -->
        <DataTemplate x:Key="LayerItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 序号 -->
                <Border Grid.Column="0" Background="#FFE8F0FE" CornerRadius="12" 
                        Width="24" Height="24" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding LayerIndex}" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               FontSize="12"/>
                </Border>

                <!-- 图标 -->
                <TextBlock Grid.Column="1" Text="{Binding FunctionIcon}" 
                           FontSize="20" HorizontalAlignment="Center"/>

                <!-- 功能名称 -->
                <TextBlock Grid.Column="2" Text="{Binding FunctionName}" 
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="13"/>

                <!-- 厚度 -->
                <TextBlock Grid.Column="3" Text="{Binding ThicknessDisplay}" 
                           VerticalAlignment="Center"
                           Foreground="#FF666666"
                           FontSize="12"/>

                <!-- 材料 -->
                <TextBlock Grid.Column="4" Text="{Binding MaterialName}" 
                           VerticalAlignment="Center"
                           Foreground="#FF888888"
                           FontSize="11"
                           FontStyle="Italic"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#FF2C3E50" Padding="10" Margin="-10,-10,-10,5" 
                CornerRadius="0,0,5,5">
            <StackPanel>
                <TextBlock Text="楼板结构层功能分析" FontSize="16" 
                           FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="显示楼板各结构层的功能类型" FontSize="11" 
                           Foreground="#FFBDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：楼板信息面板 -->
            <Border Grid.Column="0" Background="#FFF5F5F5" CornerRadius="5" 
                    Padding="10" BorderBrush="#FFE0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="📋 楼板信息" FontSize="14" 
                               FontWeight="Bold" Margin="0,0,0,10"/>

                    <Separator Margin="0,0,0,10"/>

                    <!-- 楼板详情 -->
                    <TextBlock Text="{Binding SelectedFloor.DisplayName, FallbackValue=未选择楼板}" 
                               FontWeight="SemiBold" TextWrapping="Wrap"
                               Foreground="#FF007ACC" Margin="0,0,0,10"/>

                    <Border Background="White" CornerRadius="3" Padding="8" Margin="0,5">
                        <TextBlock Text="{Binding FloorSummary}" 
                                   FontSize="11" LineHeight="18"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- 统计信息 -->
                    <Border Background="#FFE8F0FE" CornerRadius="3" Padding="8" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="📊 统计信息" FontWeight="SemiBold" 
                                       Margin="0,0,0,5" FontSize="12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="总层数:" FontSize="11"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalLayerCount}" 
                                           FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Right"/>

                                <TextBlock Grid.Column="0" Text="结构层:" FontSize="11" Margin="0,5,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding StructuralLayerCount}" 
                                           FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Right" Margin="0,5,0,0"/>

                                <TextBlock Grid.Column="0" Text="面层:" FontSize="11" Margin="0,5,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding FinishLayerCount}" 
                                           FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Right" Margin="0,5,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 刷新按钮 -->
                    <Button Content="🔄 刷新" Command="{Binding RefreshCommand}"
                            Margin="0,15,0,0" Height="32" Background="#FF007ACC" 
                            Foreground="White" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- 分隔线 -->
            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch" 
                          Background="#FFD9D9D9"/>

            <!-- 右侧：结构层列表 -->
            <Border Grid.Column="2" BorderBrush="#FFE0E0E0" BorderThickness="1" 
                    CornerRadius="5" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 列表标题 -->
                    <Border Grid.Row="0" Background="#FFF0F0F0" Padding="10" 
                            CornerRadius="5,5,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="序号" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="类型" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="功能名称" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="3" Text="厚度" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="4" Text="材料" FontWeight="Bold" FontSize="12"/>
                        </Grid>
                    </Border>

                    <!-- 数据列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Layers}" 
                                      ItemTemplate="{StaticResource LayerItemTemplate}">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Margin" Value="0"/>          
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 空状态提示 -->
                    <Border Grid.RowSpan="2" Background="#FFF5F5F5" 
                            Visibility="{Binding Layers.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="请选择一个楼板" FontSize="14" 
                                       Foreground="#FF888888" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Background="#FFF0F0F0" Height="30">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="💡 层顺序: 从外到内" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 加载遮罩 -->
        <Border Grid.RowSpan="3" Background="#CCFFFFFF" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="White" Padding="30,20" CornerRadius="8" >
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="15"
                                     Foreground="#FF007ACC"/>
                        <TextBlock Text="分析中..." Margin="0,10,0,0" 
                                   HorizontalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
