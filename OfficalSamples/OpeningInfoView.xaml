<Window x:Class="CreatePipe.OfficalSamples.OpeningInfoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
          Title="洞口X模型线创建器" Height="500" Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- 洞口列表 -->
        <GroupBox Header="洞口列表" Margin="0,0,10,0">
            <ListView ItemsSource="{Binding Openings}"
                      SelectedItem="{Binding SelectedOpening}"
                      Margin="5">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="名称" DisplayMemberBinding="{Binding Name}" Width="100"/>
                        <GridViewColumn Header="类型" DisplayMemberBinding="{Binding Type}" Width="80"/>
                        <GridViewColumn Header="ID" DisplayMemberBinding="{Binding Id.Value}" Width="60"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <!-- 预览区域 -->
        <GroupBox Grid.Column="1" Header="预览">
            <Border Background="White" BorderBrush="Gray" BorderThickness="1">
                <Image x:Name="PreviewImage" Stretch="Fill"/>
            </Border>
        </GroupBox>

        <!-- 底部按钮 -->
        <StackPanel Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0"
                    Grid.Row="1">
            <Button Content="创建X模型线" Command="{Binding CreateModelLinesCommand}"
                    Width="100" Margin="5" Background="LightBlue"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Width="60" Margin="5"/>
            <Button Content="确定" Command="{Binding OkCommand}"
                    Width="60" Margin="5" IsDefault="True"/>
            <Button Content="取消" Command="{Binding CancelCommand}"
                    Width="60" Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
