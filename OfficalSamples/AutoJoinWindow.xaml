<Window x:Class="CreatePipe.OfficalSamples.AutoJoinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
   Title="自动合并几何形体" 
        Height="550" Width="650"
        WindowStartupLocation="CenterScreen"
      xmlns:conv="clr-namespace:CreatePipe.Form.Converters">
    <Window.Resources>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:ResultBackgroundConverter x:Key="ResultBackgroundConverter"/>
        <conv:ResultForegroundConverter x:Key="ResultForegroundConverter"/>
        <conv:BooleanToResultTextConverter x:Key="BooleanToResultTextConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="自动合并重叠几何形体"
                   FontSize="18" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- 模式选择 -->
        <GroupBox Grid.Row="1" 
                  Header="执行模式" 
                  Margin="0,0,0,15">
            <StackPanel>
                <RadioButton Content="自动模式（全文档扫描）" 
                             IsChecked="{Binding IsAutoMode}"
                             Margin="5"/>
                <RadioButton Content="手动模式（仅选中构件）" 
                             IsChecked="{Binding IsAutoMode, Converter={StaticResource InverseBooleanConverter}}"
                             Margin="5,5,5,0"/>
                <TextBlock Text="{Binding ModeDescription}" 
                           FontSize="11" 
                           Foreground="Gray"
                           Margin="25,5,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <!-- 执行按钮 -->
        <Button Grid.Row="2"
                Content="开始合并"
                Command="{Binding ExecuteCommand}"
                Height="35"
                FontSize="14"
                FontWeight="Bold"
                Background="#5B9BD5"
                Foreground="White"
                Margin="0,0,0,15"
                IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>

        <!-- 处理日志区域 -->
        <GroupBox Grid.Row="3" 
                  Header="处理日志" 
                  Margin="0,0,0,15">
            <ListBox ItemsSource="{Binding LogMessages}"
                     Background="#F5F5F5"
                     FontFamily="Consolas"
                     FontSize="11">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" 
                                   TextWrapping="Wrap"
                                   Margin="3"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- 结果显示区域 -->
        <Border Grid.Row="4"
                CornerRadius="5"
                Padding="10"
                Background="{Binding LastResult.IsSuccess, 
                    Converter={StaticResource ResultBackgroundConverter}}"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock FontWeight="Bold"
                           Foreground="{Binding LastResult.IsSuccess, 
                               Converter={StaticResource ResultForegroundConverter}}">
                    <Run>执行结果：</Run>
                    <Run Text="{Binding LastResult.IsSuccess, Converter={StaticResource BooleanToResultTextConverter}}"/>
                </TextBlock>

                <TextBlock Text="{Binding LastResult.ErrorMessage}" 
                           Foreground="Red"
                           Visibility="{Binding LastResult.IsSuccess, 
                               Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding LastResult.IsSuccess, 
                                Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="合并次数：" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding LastResult.JoinedCount}" FontWeight="Bold"/>
                    <TextBlock Text="    重叠组数：" Margin="20,0,10,0"/>
                    <TextBlock Text="{Binding LastResult.OverlapGroupsCount}" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="关闭" 
                    Command="{Binding CancelCommand}"
                    Width="75"
                    IsCancel="True"/>
        </StackPanel>

        <!-- 加载遮罩 -->
        <Border Grid.RowSpan="6"
                Background="#80000000"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="250" Height="20"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           FontSize="14"
                           FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
