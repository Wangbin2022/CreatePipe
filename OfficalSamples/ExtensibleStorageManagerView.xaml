<Window x:Class="CreatePipe.OfficalSamples.ExtensibleStorageManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
         Title="可扩展存储管理器" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
         xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <Style x:Key="SectionHeaderStyle" TargetType="Label">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style x:Key="InfoLabelStyle" TargetType="Label">
            <Setter Property="Background" Value="LightGray"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">
        <!-- 状态栏 -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="Blue"/>
            </StatusBarItem>
        </StatusBar>

        <ScrollViewer>
            <StackPanel>
                <!-- 应用信息 -->
                <Label Style="{StaticResource SectionHeaderStyle}" Content="应用信息"/>
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="应用 ID"/>
                    <TextBox Grid.Column="1" Text="{Binding SchemaConfig.ApplicationId}" IsReadOnly="True"/>
                </Grid>

                <!-- Schema 配置 -->
                <Label Style="{StaticResource SectionHeaderStyle}" Content="Schema 配置"/>

                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Schema ID"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SchemaConfig.SchemaId}"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="新 GUID" Command="{Binding GenerateNewIdCommand}" Margin="5,0,0,0"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="名称"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding SchemaConfig.Name}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="描述"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding SchemaConfig.Documentation}"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="供应商 ID"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding SchemaConfig.VendorId}"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="XML 路径"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" 
                             Text="{Binding SchemaConfig.XmlPath}" IsReadOnly="True"/>
                </Grid>

                <!-- 访问权限 -->
                <Label Style="{StaticResource SectionHeaderStyle}" Content="访问权限"/>
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="读取权限"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" 
                              ItemsSource="{Binding AccessLevelOptions}"
                              SelectedValue="{Binding SchemaConfig.ReadAccess}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Level"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="写入权限"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" 
                              ItemsSource="{Binding AccessLevelOptions}"
                              SelectedValue="{Binding SchemaConfig.WriteAccess}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Level"/>
                </Grid>

                <!-- 操作按钮 -->
                <Label Style="{StaticResource SectionHeaderStyle}" Content="操作"/>

                <WrapPanel Margin="5">
                    <Button Content="创建简单 Schema" Width="180" Margin="5"
                            Command="{Binding CreateSimpleCommand}"
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>

                    <Button Content="创建复杂 Schema" Width="180" Margin="5"
                            Command="{Binding CreateComplexCommand}"
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>

                    <Button Content="从 Schema 加载" Width="150" Margin="5"
                            Command="{Binding LoadFromSchemaCommand}"
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>

                    <Button Content="从 XML 导入" Width="140" Margin="5"
                            Command="{Binding ImportFromXmlCommand}"
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>

                    <Button Content="查询 Entity" Width="120" Margin="5"
                            Command="{Binding QueryEntityCommand}"
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>

                    <Button Content="编辑 Entity" Width="120" Margin="5"
                            Command="{Binding EditEntityCommand}"
                            IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>
                </WrapPanel>

                <!-- 数据预览 -->
                <Label Style="{StaticResource SectionHeaderStyle}" Content="数据预览"/>
                <TextBox Height="150" Margin="5" 
                         Text="{Binding CurrentData.FullInfo, Mode=OneWay}"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
