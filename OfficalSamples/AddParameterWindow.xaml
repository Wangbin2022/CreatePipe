<Window x:Class="CreatePipe.OfficalSamples.AddParameterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="批量添加族参数" 
        Height="600" Width="700"
        WindowStartupLocation="CenterScreen"
      xmlns:conv="clr-namespace:CreatePipe.Form.Converters">
    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="向族文件添加参数"
                   FontSize="18" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- 模式选择 -->
        <GroupBox Grid.Row="1" Header="操作模式" Margin="0,0,0,15">
            <StackPanel>
                <RadioButton Content="单文件模式 - 向当前打开的族添加参数" 
                             IsChecked="{Binding IsBatchMode, Converter={StaticResource InverseBooleanConverter}}"
                             Margin="5"/>
                <RadioButton Content="批量模式 - 向文件夹中所有族文件添加参数" 
                             IsChecked="{Binding IsBatchMode}"
                             Margin="5"/>
            </StackPanel>
        </GroupBox>

        <!-- 文件夹选择（批量模式） -->
        <Border Grid.Row="2" 
                Visibility="{Binding IsBatchMode, Converter={StaticResource BoolToVisibilityConverter}}"
                Margin="0,0,0,15">
            <GroupBox Header="文件夹设置">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" 
                             Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"/>
                    <Button Grid.Column="1" 
                            Content="浏览..."
                            Command="{Binding BrowseFolderCommand}"
                            Width="60"
                            Margin="5,0,0,0"/>
                    <TextBlock Grid.Column="2"  Text="提示：需要在[我的文档]下创建 AutoParameter_Families 文件夹存放族文件"
                           FontSize="11"
                           Foreground="Gray"
                           Margin="0,5,0,0"/>
                </Grid>
            </GroupBox>
        </Border>

        <!-- 参数文件说明 -->
        <Border Grid.Row="3" 
                Background="#FFF3E0" 
                CornerRadius="5"
                Padding="10"
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock FontWeight="Bold" Foreground="#E65100">
                    参数文件要求：
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="11">
                    • 在插件程序目录下放置 FamilyParameter.txt 和/或 SharedParameter.txt
                    <LineBreak/>
                    • 格式：参数名称 参数分组 参数类型 是否实例
                    <LineBreak/>
                    • 示例：Width PG_Length Length  true
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 日志区域 -->
        <GroupBox Grid.Row="4" Header="处理日志" Margin="0,0,0,15">
            <ListBox ItemsSource="{Binding LogMessages}"
                     Background="#1E1E1E"
                     Foreground="#D4D4D4"
                     FontFamily="Consolas"
                     FontSize="11">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- 按钮栏 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="开始执行"
                    Command="{Binding ExecuteCommand}"
                    IsEnabled="{Binding CanExecute}"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Background="#5B9BD5"
                    Foreground="White"/>
            <Button Content="关闭"
                    Command="{Binding CancelCommand}"
                    Width="75"
                    Height="30"
                    IsCancel="True"/>
        </StackPanel>

        <!-- 加载遮罩 -->
        <Border Grid.RowSpan="6"
                Background="#80000000"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="250" Height="20"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
