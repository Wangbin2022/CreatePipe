<Window x:Class="CreatePipe.OfficalSamples.GenericStructuralConnectionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
       Title="结构连接操作" 
        Height="450" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <local:EnumToBooleanConverter2  x:Key="EnumToBooleanConverter"/>
        <!-- 样式: 命令按钮组 -->
        <Style x:Key="CommandRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <!-- 样式: 状态标签 -->
        <Style x:Key="StatusLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="结构连接管理工具" 
                   FontSize="16" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- 命令分组 -->
        <GroupBox Grid.Row="1" Header="通用连接操作" Margin="0,5">
            <StackPanel>
                <RadioButton Content="创建通用结构连接" 
                             GroupName="Commands"
                             IsChecked="{Binding SelectedCommand, Converter={StaticResource EnumToBooleanConverter}, 
                                          ConverterParameter=CreateGeneric}"
                             Style="{StaticResource CommandRadioButtonStyle}"/>
                <RadioButton Content="删除通用结构连接" 
                             GroupName="Commands"
                             IsChecked="{Binding SelectedCommand, Converter={StaticResource EnumToBooleanConverter}, 
                                          ConverterParameter=DeleteGeneric}"
                             Style="{StaticResource CommandRadioButtonStyle}"/>
                <RadioButton Content="读取通用结构连接信息" 
                             GroupName="Commands"
                             IsChecked="{Binding SelectedCommand, Converter={StaticResource EnumToBooleanConverter}, 
                                          ConverterParameter=ReadGeneric}"
                             Style="{StaticResource CommandRadioButtonStyle}"/>
                <RadioButton Content="更新通用结构连接" 
                             GroupName="Commands"
                             IsChecked="{Binding SelectedCommand, Converter={StaticResource EnumToBooleanConverter}, 
                                          ConverterParameter=UpdateGeneric}"
                             Style="{StaticResource CommandRadioButtonStyle}"/>
            </StackPanel>
        </GroupBox>

        <!-- 详细连接操作分组 -->
        <GroupBox Grid.Row="2" Header="详细连接操作" Margin="0,5">
            <StackPanel>
                <RadioButton Content="创建详细结构连接" 
                             GroupName="Commands"
                             IsChecked="{Binding SelectedCommand, Converter={StaticResource EnumToBooleanConverter}, 
                                          ConverterParameter=CreateDetailed}"
                             Style="{StaticResource CommandRadioButtonStyle}"/>
                <RadioButton Content="更改详细连接类型" 
                             GroupName="Commands"
                             IsChecked="{Binding SelectedCommand, Converter={StaticResource EnumToBooleanConverter}, 
                                          ConverterParameter=ChangeDetailed}"
                             Style="{StaticResource CommandRadioButtonStyle}"/>
                <RadioButton Content="复制详细连接" 
                             GroupName="Commands"
                             IsChecked="{Binding SelectedCommand, Converter={StaticResource EnumToBooleanConverter}, 
                                          ConverterParameter=CopyDetailed}"
                             Style="{StaticResource CommandRadioButtonStyle}"/>
                <RadioButton Content="匹配详细连接属性" 
                             GroupName="Commands"
                             IsChecked="{Binding SelectedCommand, Converter={StaticResource EnumToBooleanConverter}, 
                                          ConverterParameter=MatchPropDetailed}"
                             Style="{StaticResource CommandRadioButtonStyle}"/>
                <RadioButton Content="重置为通用连接" 
                             GroupName="Commands"
                             IsChecked="{Binding SelectedCommand, Converter={StaticResource EnumToBooleanConverter}, 
                                          ConverterParameter=ResetDetailed}"
                             Style="{StaticResource CommandRadioButtonStyle}"/>
            </StackPanel>
        </GroupBox>

        <!-- 状态栏和按钮区 -->
        <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
            <TextBlock Text="{Binding StatusMessage, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource StatusLabelStyle}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="执行" Command="{Binding ExecuteCommand}"
                        Width="75" Height="25" Margin="0,0,10,0"
                        Background="#4CAF50" Foreground="White"/>
                <Button Content="取消" Command="{Binding CancelCommand}"
                        Width="75" Height="25" Background="#E0E0E0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
