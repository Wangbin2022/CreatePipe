<Window x:Class="CreatePipe.OfficalSamples.DoorOperatorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
      Title="门构件操作工具" Height="500" Width="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 按钮样式 -->
        <Style x:Key="OperationButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="门构件列表" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="刷新列表" Command="{Binding RefreshCommand}" 
                        Width="80" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" 
                           Foreground="Gray" FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- 门列表 -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Doors}" 
                  SelectedItem="{Binding SelectedDoor}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="门族" Binding="{Binding FamilyName}" Width="*"/>
                <DataGridTextColumn Header="类型" Binding="{Binding TypeName}" Width="*"/>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Margin="0,5">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage, FallbackValue='就绪'}" />
            </StatusBarItem>
        </StatusBar>

        <!-- 操作按钮区域 -->
        <Border Grid.Row="3" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="0,10,0,0">
            <StackPanel>
                <!-- 方向调整 -->
                <GroupBox Header="方向调整" Margin="0,0,0,5">
                    <StackPanel>
                        <WrapPanel Margin="5">
                            <Button Content="← 左开 (Left)" Command="{Binding MakeLeftCommand}" 
                                    Style="{StaticResource OperationButtonStyle}"/>
                            <Button Content="右开 (Right) →" Command="{Binding MakeRightCommand}" 
                                    Style="{StaticResource OperationButtonStyle}"/>
                            <Button Content="翻转把手" Command="{Binding FlipHandCommand}" 
                                    Style="{StaticResource OperationButtonStyle}"/>
                        </WrapPanel>
                        <WrapPanel Margin="5">
                            <Button Content="内开 (In) ↓" Command="{Binding TurnInCommand}" 
                                    Style="{StaticResource OperationButtonStyle}"/>
                            <Button Content="外开 (Out) ↑" Command="{Binding TurnOutCommand}" 
                                    Style="{StaticResource OperationButtonStyle}"/>
                            <Button Content="翻转朝向" Command="{Binding FlipFacingCommand}" 
                                    Style="{StaticResource OperationButtonStyle}"/>
                        </WrapPanel>
                        <WrapPanel Margin="5">
                            <Button Content="⟳ 旋转180°" Command="{Binding RotateCommand}" 
                                    Style="{StaticResource OperationButtonStyle}"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <!-- 删除操作 -->
                <GroupBox Header="删除" Margin="0,0,0,5">
                    <WrapPanel Margin="5">
                        <Button Content="🗑 删除选中门" Command="{Binding DeleteCommand}" 
                                Style="{StaticResource OperationButtonStyle}"
                                Background="#FFE0E0E0"/>
                    </WrapPanel>
                </GroupBox>

                <!-- 提示信息 -->
                <TextBlock Text="提示：请先在列表中选择一个门构件，然后点击操作按钮" 
                           FontSize="10" Foreground="Gray" Margin="5,0,0,5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
