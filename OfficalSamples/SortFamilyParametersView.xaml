<Window x:Class="CreatePipe.OfficalSamples.SortFamilyParametersView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
        Title="族参数排序工具" Height="550" Width="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        
        <Style x:Key="SectionHeaderStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 目录选择区域 -->
        <GroupBox Grid.Row="0" Header="族文件目录" Style="{StaticResource SectionHeaderStyle}">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding DirectoryPath, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"
                         VerticalAlignment="Center"/>

                <Button Grid.Column="1" Content="浏览..." Width="70" Margin="5,0,0,0"
                        Command="{Binding BrowseDirectoryCommand}"
                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>

                <Button Grid.Column="2" Content="批量排序" Width="80" Margin="5,0,0,0"
                        Command="{Binding SortFilesCommand}"
                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>
            </Grid>
        </GroupBox>

        <!-- 排序选项区域 -->
        <GroupBox Grid.Row="1" Header="排序选项" Style="{StaticResource SectionHeaderStyle}">
            <StackPanel Margin="5" Orientation="Horizontal">
                <RadioButton Content="A → Z (升序)" 
                             IsChecked="{Binding SelectedDirection, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Ascending}"
                             IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"
                             Margin="0,0,15,0"/>
                <RadioButton Content="Z → A (降序)" 
                             IsChecked="{Binding SelectedDirection, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Descending}"
                             IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>
            </StackPanel>
        </GroupBox>

        <!-- 处理当前文档区域 -->
        <GroupBox Grid.Row="2" Header="已加载族" Style="{StaticResource SectionHeaderStyle}">
            <StackPanel Margin="5" Orientation="Horizontal">
                <Button Content="排序当前文档中的族参数" Width="180" Height="30"
                        Command="{Binding SortLoadedFamiliesCommand}"
                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>
                <TextBlock Text="（适用于当前打开的族文档）" 
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           Foreground="Gray" FontSize="11"/>
            </StackPanel>
        </GroupBox>

        <!-- 进度日志区域 -->
        <GroupBox Grid.Row="3" Header="处理日志" Style="{StaticResource SectionHeaderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 进度条 -->
                <ProgressBar Grid.Row="0" Height="20" Margin="0,0,0,5"
                             Minimum="0" Maximum="{Binding TotalProgress}"
                             Value="{Binding CurrentProgress}"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- 状态文本 -->
                <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" 
                           Margin="0,0,0,5" FontWeight="Bold"
                           Visibility="{Binding IsProcessing, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                <!-- 日志列表 -->
                <ListBox Grid.Row="1" ItemsSource="{Binding ProgressLog}"
                         FontFamily="Consolas" FontSize="11"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="关闭" Width="80" Height="30"
                    Command="{Binding CloseCommand}"/>
        </StackPanel>
    </Grid>
</Window>
