<Window x:Class="CreatePipe.OfficalSamples.TypeSelectorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
       Title="Revit 类型选择器" 
        Height="450" Width="550"
        WindowStartupLocation="CenterOwner"
        MinHeight="400" MinWidth="500"
        mc:Ignorable="d"
       xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <local:TypeItemTemplateSelector x:Key="TypeItemTemplateSelector"/>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
        <local:StatusTextConverter x:Key="StatusTextConverter"/>

        <!-- 类型项模板 -->
        <DataTemplate x:Key="TypeItemTemplate">
            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" 
                    Background="{Binding IsSelected, Converter={StaticResource BooleanToBrushConverter}}">
                <Grid Margin="10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Name}" 
                                   FontWeight="Bold" 
                                   FontSize="13"/>
                        <TextBlock Text="{Binding Description}" 
                                   FontSize="10" 
                                   Foreground="Gray"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" 
                            Background="{Binding IsSelected, Converter={StaticResource StatusColorConverter}}"
                            CornerRadius="10"
                            Width="50"
                            Height="22"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding IsSelected, Converter={StaticResource StatusTextConverter}}"
                                   FontSize="9"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- 搜索框样式 -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDBDBD"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEEEEE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="5">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#2196F3" CornerRadius="5" Padding="12,10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Revit 类型选择器" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="更改墙体或构件的类型" Foreground="#E0E0E0" FontSize="11" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- 元素信息区域 -->
            <Border Grid.Row="1" Background="#FFF9C4" CornerRadius="5" Padding="12" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="📦 " FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding CurrentElementInfo}" 
                               FontWeight="SemiBold" 
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 工具栏 -->
            <Border Grid.Row="2" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 搜索框（可选功能） -->
                    <TextBox Grid.Column="0" Style="{StaticResource SearchTextBoxStyle}"
                             x:Name="SearchBox"
                             TextChanged="SearchBox_TextChanged"
                             Tag="搜索类型..."/>

                    <!-- 刷新按钮 -->
                    <Button Grid.Column="1" 
                            Content="🔄 刷新" 
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="12,5"/>
                </Grid>
            </Border>

            <!-- 类型列表区域 -->
            <GroupBox Grid.Row="3" Header="可用类型列表" Margin="0,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 统计信息 -->
                    <Border Grid.Row="0" Background="#F5F5F5" Padding="8" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="{Binding StatusMessage}" 
                                       FontSize="11"
                                       Foreground="Gray"/>

                            <TextBlock Grid.Column="1" 
                                       Text="{Binding TypeIndexDisplay}" 
                                       FontSize="11"
                                       Foreground="Gray"/>
                        </Grid>
                    </Border>

                    <!-- 类型列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding AvailableTypes}"
                                 SelectedItem="{Binding SelectedType, Mode=TwoWay}"
                                 ItemTemplate="{StaticResource TypeItemTemplate}"
                                 BorderThickness="0"
                                 Background="White">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </ScrollViewer>

                    <!-- 加载指示器 -->
                    <Border Grid.Row="1" Background="#CCFFFFFF" 
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar Width="200" Height="10" IsIndeterminate="True"/>
                            <TextBlock Text="加载中..." Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 空状态提示 -->
                    <TextBlock Grid.Row="1" 
                               Text="暂无可用类型"
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               FontSize="14"
                               Visibility="{Binding AvailableTypes.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                </Grid>
            </GroupBox>

            <!-- 进度指示器 -->
            <ProgressBar Grid.Row="4" Height="3" IsIndeterminate="{Binding IsLoading}"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                         Margin="0,10,0,10"/>

            <!-- 按钮区域 -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="取消" Click="CancelButton_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Content="确定" Command="{Binding OkCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
