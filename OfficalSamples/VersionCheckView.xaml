<Window x:Class="CreatePipe.OfficalSamples.VersionCheckView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
      Title="关于 Revit"   Height="400" Width="500"
        WindowStartupLocation="CenterOwner"  ResizeMode="NoResize" ShowInTaskbar="False"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <!-- 加载状态转换器 -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- 版本信息样式 -->
        <Style x:Key="VersionInfoTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas, Courier New, monospace"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <Border Grid.Row="0" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="10" 
                Margin="0,0,0,15">
            <!--<Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#FF416A"/>
                    <GradientStop Offset="1" Color="#FF1B3A"/>
                </LinearGradientBrush>
            </Border.Background>-->

            <StackPanel>
                <TextBlock Text="Revit 版本信息" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Revit Version Information" 
                           FontSize="11" 
                           Foreground="#E0E0E0" 
                           HorizontalAlignment="Center" 
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 加载进度指示器 -->
        <ProgressBar Grid.Row="1" 
                     Height="4" 
                     IsIndeterminate="{Binding IsLoading}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                     VerticalAlignment="Top"
                     Margin="0,0,0,10"/>

        <!-- 版本信息显示区域 -->
        <Border Grid.Row="1" 
                BorderBrush="#DDDDDD" 
                BorderThickness="1" 
                CornerRadius="6" 
                Padding="15"
                Background="#F9F9F9"
                Height="Auto"
                MinHeight="250">
            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock Text="{Binding VersionInfo.FormattedInfo, Mode=OneWay}" 
                           Style="{StaticResource VersionInfoTextStyle}"
                           LineHeight="22"/>
            </ScrollViewer>
        </Border>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,15,0,15">
            <Button Content="复制到剪贴板" 
                    Command="{Binding CopyToClipboardCommand}"
                    Width="120" 
                    Height="30"
                    Margin="0,0,10,0"
                    Padding="5">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#F0F0F0"/>
                        <Setter Property="BorderBrush" Value="#999999"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="关闭" 
                    Command="{Binding CloseCommand}"
                    Width="80" 
                    Height="30"
                    IsCancel="True"
                    Padding="5">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#E74C3C"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C0392B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#A93226"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- 版权信息 -->
        <TextBlock Grid.Row="3" 
                   Text="© Autodesk, Inc. 保留所有权利" 
                   FontSize="9" 
                   Foreground="#999999" 
                   HorizontalAlignment="Center"/>
    </Grid>
</Window>
