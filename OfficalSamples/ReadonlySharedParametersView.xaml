<Window x:Class="CreatePipe.OfficalSamples.ReadonlySharedParametersView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
      Title="只读共享参数管理器" Height="450" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 说明标题 -->
        <TextBlock Grid.Row="0" 
                   Text="选择要执行的操作："
                   FontSize="14"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- 操作列表 -->
        <ListView Grid.Row="1" 
                  ItemsSource="{Binding Operations}"
                  Margin="0,0,0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="执行" Width="50">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="操作名称" DisplayMemberBinding="{Binding DisplayName}" Width="180"/>
                    <GridViewColumn Header="说明" DisplayMemberBinding="{Binding Description}" Width="250"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,10">
            <Button Content="执行选中" Command="{Binding ExecuteSelectedCommand}"
                    Width="100" Height="30" Margin="5"
                    IsEnabled="{Binding CanExecute}"
                    Background="LightGreen"/>
            <Button Content="执行全部" Command="{Binding ExecuteAllCommand}"
                    Width="100" Height="30" Margin="5"
                    IsEnabled="{Binding CanExecute}"/>
            <Button Content="全选" Command="{Binding SelectAllCommand}"
                    Width="80" Height="30" Margin="5"/>
            <Button Content="清空" Command="{Binding DeselectAllCommand}"
                    Width="80" Height="30" Margin="5"/>
            <Button Content="关闭" Command="{Binding CancelCommand}"
                    Width="80" Height="30" Margin="5"/>
        </StackPanel>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="Gray"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 处理中覆盖层 -->
        <Border Background="#CCFFFFFF" 
                Grid.RowSpan="4"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="执行中..." FontSize="16" FontWeight="Bold"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="15" Margin="0,10"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
