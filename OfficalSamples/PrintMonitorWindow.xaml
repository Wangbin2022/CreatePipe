<Window x:Class="CreatePipe.OfficalSamples.PrintMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
  Title="打印事件监控器" 
        Height="650" Width="800"
        WindowStartupLocation="CenterScreen"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">
    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:ResultBackgroundConverter x:Key="ResultBackgroundConverter"/>
        <conv:StatusColorConverter x:Key="StatusColorConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="打印事件监控与自动水印"
                   FontSize="18" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- 状态栏 -->
        <Border Grid.Row="1" 
                Background="{Binding IsMonitoring, Converter={StaticResource ResultBackgroundConverter}}"
                CornerRadius="5"
                Padding="10"
                Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12" Height="12" 
                         Fill="{Binding IsMonitoring, Converter={StaticResource StatusColorConverter}}"
                         VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- 主内容区域 -->
        <TabControl Grid.Row="2">
            <!-- 水印设置标签页 -->
            <TabItem Header="水印设置">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="水印内容" Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel Margin="10">
                            <CheckBox Content="包含打印机信息" 
                                      IsChecked="{Binding IncludePrinterInfo}"
                                      Margin="0,5"/>
                            <CheckBox Content="包含用户名信息" 
                                      IsChecked="{Binding IncludeUserInfo}"
                                      Margin="0,5"/>

                            <TextBlock Text="自定义文字（当以上选项未选中时使用）" 
                                       Margin="0,15,0,5"/>
                            <TextBox Text="{Binding WatermarkText}"
                                     IsEnabled="{Binding IncludePrinterInfo, Converter={StaticResource InverseBooleanConverter}}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="水印格式" Grid.Row="1" Margin="0,0,0,10">
                        <StackPanel Margin="10">
                            <TextBlock Text="水平对齐方式" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding AlignmentOptions}"
                                      SelectedIndex="{Binding HorizontalAlignmentIndex}"
                                      Width="150"
                                      HorizontalAlignment="Left"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="说明" Grid.Row="2">
                        <TextBlock TextWrapping="Wrap" Margin="10" FontSize="12">
                            • 启动监控后，当您打印视图时会自动在视图中心添加水印
                            <LineBreak/>
                            • 水印内容包含打印机名称和当前用户名
                            <LineBreak/>
                            • 打印完成后水印会自动删除
                            <LineBreak/>
                            • 所有打印事件都会被记录到下方日志中
                        </TextBlock>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- 事件日志标签页 -->
            <TabItem Header="事件日志">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                        <Button Content="清空日志" 
                                Command="{Binding ClearLogsCommand}"
                                Width="80"
                                Margin="0,0,10,0"/>
                        <Button Content="导出日志" 
                                Command="{Binding ExportLogCommand}"
                                Width="80"/>
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding EventLogs}"
                             Background="#1E1E1E"
                             Foreground="#D4D4D4"
                             FontFamily="Consolas"
                             FontSize="11">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FormattedLog}" 
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 按钮栏 -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,15,0,0">
            <Button Content="开始监控" 
                    Command="{Binding StartMonitoringCommand}"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Background="#5B9BD5"
                    Foreground="White"
                    FontWeight="Bold"
                    Visibility="{Binding IsMonitoring, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

            <Button Content="停止监控" 
                    Command="{Binding StopMonitoringCommand}"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Background="#E74C3C"
                    Foreground="White"
                    FontWeight="Bold"
                    Visibility="{Binding IsMonitoring, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <Button Content="关闭" 
                    Command="{Binding CancelCommand}"
                    Width="75"
                    Height="30"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
