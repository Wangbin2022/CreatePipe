<Window x:Class="CreatePipe.OfficalSamples.ReferencePlaneMgrView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
   Title="参考平面管理器" Height="400" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 说明 -->
        <TextBlock Grid.Row="0" 
                   Text="提示：选中墙或楼板后点击「创建」按钮，将在选中的构件上创建参考平面。"
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   Margin="0,0,0,10"/>

        <!-- 参考平面列表 -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding ReferencePlanes}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="气泡端" Binding="{Binding BubbleEnd}" Width="160"/>
                <DataGridTextColumn Header="自由端" Binding="{Binding FreeEnd}" Width="160"/>
                <DataGridTextColumn Header="法线" Binding="{Binding Normal}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="创建参考平面" 
                    Command="{Binding CreateCommand}"
                    Width="110" Height="30" 
                    Margin="5"
                    Background="LightGreen"
                    IsEnabled="{Binding CanExecute}"/>
            <Button Content="刷新列表" 
                    Command="{Binding RefreshCommand}"
                    Width="80" Height="30" 
                    Margin="5"/>
            <Button Content="关闭" 
                    Command="{Binding CancelCommand}"
                    Width="60" Height="30" 
                    Margin="5" IsCancel="True"/>
        </StackPanel>

        <!-- 处理中覆盖层 -->
        <Border Background="#CCFFFFFF" 
                Grid.RowSpan="3"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="创建中..." 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       FontSize="16"/>
        </Border>
    </Grid>
</Window>
