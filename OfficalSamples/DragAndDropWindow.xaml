<Window x:Class="CreatePipe.OfficalSamples.DragAndDropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
         Title="家具族管理器 - 拖放式加载/卸载" 
        Height="600" Width="1100"
        WindowStartupLocation="CenterOwner"
        mc:Ignorable="d"
         xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
        <local:StatusTextConverter x:Key="StatusTextConverter"/>

        <!-- 家具族项目模板 -->
        <DataTemplate x:Key="FurnitureItemTemplate">
            <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5" Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12"/>
                        <TextBlock Text="{Binding Status}" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="{Binding Path}" FontSize="9" Foreground="LightGray" 
                                   Visibility="{Binding Path, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>

                    <Border Grid.Column="1" 
                            Background="{Binding IsLoaded, Converter={StaticResource StatusColorConverter}}"
                            CornerRadius="10"
                            Width="60"
                            Height="20"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding IsLoaded, Converter={StaticResource StatusTextConverter}}"
                                   FontSize="9"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- 拖放目标装饰样式 -->
        <Style x:Key="DragDropTargetStyle" TargetType="ListBox">
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                    <Setter Property="BorderThickness" Value="3"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#2196F3" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="家具族管理器" Foreground="White" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="通过拖放操作加载或卸载家具族文件" Foreground="#E0E0E0" FontSize="11" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 工具栏 -->
        <ToolBar Grid.Row="1" Margin="0,0,0,10">
            <Button Content="刷新" Command="{Binding RefreshCommand}" Margin="5">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4CAF50"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Separator/>

            <StackPanel Orientation="Horizontal" Margin="10,0">
                <TextBlock Text="族库路径:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding CurrentFolderPath, UpdateSourceTrigger=PropertyChanged}" 
                         Width="300" Height="25"/>
                <Button Content="浏览..." Command="{Binding BrowseFolderCommand}" Margin="5,0,0,0"/>
            </StackPanel>
        </ToolBar>

        <!-- 进度指示器 -->
        <ProgressBar Grid.Row="2" Height="3" IsIndeterminate="{Binding IsProcessing}"
                     Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"
                     VerticalAlignment="Top"/>

        <!-- 主内容区域 - 两个拖放列表 -->
        <Grid Grid.Row="2" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 已加载的族列表 -->
            <GroupBox Grid.Column="0" Header="已加载的家具族（拖出可卸载）" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="↓ 从右侧拖放到此区域以加载族" 
                               Foreground="#4CAF50" FontSize="10" Margin="5" 
                               Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Reverse}"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding LoadedFamilies}"
                             SelectedItem="{Binding SelectedLoadedFamily}"
                             ItemTemplate="{StaticResource FurnitureItemTemplate}"
                             Style="{StaticResource DragDropTargetStyle}"
                             AllowDrop="True"
                             Drop="ListBox_Drop"
                             DragOver="ListBox_DragOver"
                             MouseMove="ListBox_MouseMove"
                             PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown">

                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Resources>
                    </ListBox>

                    <!-- 空状态提示 -->
                    <TextBlock Grid.Row="1" Text="暂无已加载的家具族"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="Gray"
                               Visibility="{Binding LoadedFamilies.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                </Grid>
            </GroupBox>

            <!-- 中间指示器 -->
            <Border Grid.Column="1" 
                    Background="#F0F0F0" 
                    CornerRadius="5"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    VerticalAlignment="Center"
                    Height="80">
                <TextBlock Text="⟷" 
                           FontSize="24" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="#999"/>
            </Border>

            <!-- 可用的族文件列表 -->
            <GroupBox Grid.Column="2" Header="可用的家具族文件（拖入可加载）" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="→ 从左侧拖放到此区域以卸载族" 
                               Foreground="#F44336" FontSize="10" Margin="5"
                               Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Reverse}"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding AvailableFamilies}"
                             SelectedItem="{Binding SelectedAvailableFamily}"
                             ItemTemplate="{StaticResource FurnitureItemTemplate}"
                             Style="{StaticResource DragDropTargetStyle}"
                             AllowDrop="True"
                             Drop="ListBox_Drop"
                             DragOver="ListBox_DragOver"
                             MouseMove="ListBox_MouseMove"
                             PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown">
                    </ListBox>

                    <!-- 空状态提示 -->
                    <TextBlock Grid.Row="1" Text="在当前文件夹中未找到家具族文件"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="Gray"
                               Visibility="{Binding AvailableFamilies.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="提示：可以直接在两个列表之间拖拽项目进行加载或卸载操作" 
                           Foreground="Gray" FontSize="10"/>
            </StatusBarItem>
            <Separator/>
            <!--<StatusBarItem>
                <TextBlock Text="已加载族数量: " />
                <TextBlock Text="{Binding LoadedFamilies.Count}" FontWeight="Bold"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="可用族数量: " />
                <TextBlock Text="{Binding AvailableFamilies.Count}" FontWeight="Bold"/>
            </StatusBarItem>-->
        </StatusBar>
    </Grid>
</Window>
