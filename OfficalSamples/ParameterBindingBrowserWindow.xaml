<Window x:Class="CreatePipe.OfficalSamples.ParameterBindingBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      Title="参数绑定浏览器" 
        Height="500" Width="450"
        WindowStartupLocation="CenterScreen"
        MinHeight="400" MinWidth="350"      
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <!-- 参数绑定信息的数据模板 -->
        <HierarchicalDataTemplate DataType="{x:Type local:ParameterBindingInfo}" 
                                  ItemsSource="{Binding Categories}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ParameterName}" FontWeight="Bold"/>
                <TextBlock Text=" (" Foreground="Gray"/>
                <TextBlock Text="{Binding CategoryCount}" Foreground="Gray"/>
                <TextBlock Text="个类别)" Foreground="Gray"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- 类别字符串的数据模板 -->
        <DataTemplate DataType="{x:Type system:String}">
            <StackPanel Orientation="Horizontal" Margin="20,2,0,2">
                <Ellipse Width="6" Height="6" Fill="#5B9BD5" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding}" FontSize="12"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="参数绑定浏览器"
                   FontSize="16" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- 说明文字 -->
        <TextBlock Grid.Row="1" 
                   TextWrapping="Wrap"
                   FontSize="11"
                   Foreground="#555555"
                   Margin="0,0,0,10">
            显示当前文档中所有已绑定的共享参数及其关联的构件类别。
            <LineBreak/>
            每个参数可以绑定到多个类别，表示该参数可用于这些类别的构件。
        </TextBlock>

        <!-- 参数绑定树形视图 -->
        <GroupBox Grid.Row="2" 
                  Header="参数绑定列表" 
                  Margin="0,0,0,10">
            <TreeView ItemsSource="{Binding Bindings}"
                      SelectedValuePath="{Binding SelectedBinding}"
                      BorderThickness="0">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                        <Setter Property="Foreground" Value="#333333"/>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </GroupBox>

        <!-- 统计信息栏 -->
        <Border Grid.Row="3" 
                Background="#F5F5F5" 
                CornerRadius="5"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding SummaryText}" 
                           FontWeight="Bold"
                           Foreground="#2E7032"
                           TextAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="11"
                           Foreground="Gray"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 按钮栏 -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="刷新" 
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding CanRefresh}"
                    Width="70"
                    Height="30"
                    Margin="0,0,10,0"/>
            <Button Content="关闭" 
                    Command="{Binding CloseCommand}"
                    Width="70"
                    Height="30"
                    IsCancel="True"/>
        </StackPanel>

        <!-- 加载遮罩 -->
        <Border Grid.RowSpan="5"
                Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="15"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
