<Window x:Class="CreatePipe.OfficalSamples.DesignOptionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
   Title="设计选项查看器" Height="450" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="350" MinWidth="400"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:SuccessToForegroundConverter x:Key="SuccessToForegroundConverter"/>
        <local:IndexConverter x:Key="IndexConverter"/>
        
        <SolidColorBrush x:Key="SuccessBrush" Color="#D4EDDA"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFF3CD"/>
        <SolidColorBrush x:Key="SuccessForegroundBrush" Color="#155724"/>
        <SolidColorBrush x:Key="WarningForegroundBrush" Color="#856404"/>

        <Style x:Key="DesignOptionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F4FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="设计选项查看器" FontSize="16" FontWeight="Bold" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="查看当前Revit文档中的所有设计选项" 
                           FontSize="12" Foreground="Gray" 
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- 信息卡片 -->
            <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="5" 
                    BorderBrush="#DEE2E6" BorderThickness="1" Padding="12" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="📋" FontSize="20" Margin="0,0,10,0"/>

                    <TextBlock Grid.Column="1" 
                               Text="{Binding ExecutionResult.Message, FallbackValue=就绪}"
                               Foreground="{Binding ExecutionResult.Success, 
                                      Converter={StaticResource SuccessToForegroundConverter}}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>

                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="🔄 刷新" Width="70" Height="28"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
                </Grid>
            </Border>

            <!-- 设计选项列表 -->
            <GroupBox Grid.Row="2" Header="设计选项列表" Margin="0,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 列表头部 -->
                    <Border Grid.Row="0" Background="#F8F9FA" Padding="8,5" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="#"/>
                            <TextBlock Grid.Column="1" Text="设计选项名称" Margin="10,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="成员数量" Margin="0,0,10,0"/>
                        </Grid>
                    </Border>

                    <!-- 列表内容 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DesignOptions.DesignOptions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" 
                                            Padding="8,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, 
                                                              Converter={StaticResource IndexConverter}}"
                                                       Foreground="Gray"/>

                                            <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                                       Margin="10,0,0,0" FontWeight="SemiBold"/>

                                            <Border Grid.Column="2" 
                                                    Background="#E8F4FD" CornerRadius="10"
                                                    Padding="8,2">
                                                <TextBlock Text="{Binding MemberCount}" 
                                                           FontSize="11" Foreground="#007ACC"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 空状态 -->
                    <TextBlock Grid.RowSpan="2" Text="暂无设计选项"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="Gray"
                               Visibility="{Binding HasDesignOptions, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                </Grid>
            </GroupBox>

            <!-- 统计信息 -->
            <Border Grid.Row="3" Background="#F8F9FA" CornerRadius="5" Padding="10" Margin="0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="共" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DesignOptionCount}" FontWeight="Bold" Margin="3,0"/>
                        <TextBlock Text="个设计选项"/>
                    </StackPanel>

                    <Button Grid.Column="1" Command="{Binding CopyToClipboardCommand}"
                            Content="📋 复制列表" Width="90" Height="28"
                            IsEnabled="{Binding HasDesignOptions}"/>
                </Grid>
            </Border>

            <!-- 按钮区域 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" 
                        HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Command="{Binding CloseCommand}" 
                        Content="关闭" Width="80" Height="30"/>
            </StackPanel>

            <!-- 加载进度 -->
            <Border Grid.RowSpan="5" Background="#80FFFFFF" 
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
