<Window x:Class="CreatePipe.OfficalSamples.StructuralFrameBuilderView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
      Title="结构框架生成器" Height="550" Width="700"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">
    <Window.Resources>
        <conv:InverseBooleanConverter   x:Key="InverseBooleanConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 布局参数区域 -->
        <GroupBox Grid.Row="0" Header="布局参数" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="X方向柱数量:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Config.XNumber, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="(2-50)" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Y方向柱数量:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Config.YNumber, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="(2-50)" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="柱间距(英尺):" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Config.Distance, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="(1-3000)" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- 2. 楼层参数区域 -->
        <GroupBox Grid.Row="1" Header="楼层参数" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="楼层数量:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Column="1" Text="{Binding Config.FloorNumber, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <TextBlock Grid.Column="2" Text="(1-200)" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="层高(英尺):" VerticalAlignment="Center" Margin="5" Visibility="Collapsed"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Config.LevelHeight, UpdateSourceTrigger=PropertyChanged}" Margin="5" Visibility="Collapsed"/>
            </Grid>
        </GroupBox>

        <!-- 3. 位置参数区域 -->
        <GroupBox Grid.Row="2" Header="位置参数" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="原点 X:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Config.OriginX, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="英尺" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="原点 Y:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Config.OriginY, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="英尺" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="旋转角度:" VerticalAlignment="Center" Margin="5"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Config.RotateAngle, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="弧度" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- 4. 构件类型选择区域 -->
        <GroupBox Grid.Row="3" Header="构件类型" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="柱类型:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding ColumnTypes}" 
                          SelectedItem="{Binding SelectedColumn}" DisplayMemberPath="Name" Margin="5"/>
                <Button Grid.Row="0" Grid.Column="2" Content="复制" Width="60" Margin="5" Command="{Binding DuplicateColumnCommand}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="梁类型:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding BeamTypes}" 
                          SelectedItem="{Binding SelectedBeam}" DisplayMemberPath="Name" Margin="5"/>
                <Button Grid.Row="1" Grid.Column="2" Content="复制" Width="60" Margin="5" Command="{Binding DuplicateBeamCommand}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="支撑类型:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding BraceTypes}" 
                          SelectedItem="{Binding SelectedBrace}" DisplayMemberPath="Name" Margin="5"/>
                <Button Grid.Row="2" Grid.Column="2" Content="复制" Width="60" Margin="5" Command="{Binding DuplicateBraceCommand}"/>
            </Grid>
        </GroupBox>

        <!-- 5. 状态栏 -->
        <StatusBar Grid.Row="4" Margin="0,0,0,5">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="Blue"/>
            </StatusBarItem>
            <!--<StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="总柱子数: " />
                <TextBlock Text="{Binding Config.TotalColumns}" FontWeight="Bold"/>
                <TextBlock Text=" / " />
                <TextBlock Text="{x:Static local:Models.FrameConfiguration.TotalMaxColumns}"/>
            </StatusBarItem>-->
        </StatusBar>

        <!-- 6. 按钮区域 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5">
            <Button Content="生成框架" Width="100" Height="30" Margin="0,0,10,0"
                    Command="{Binding BuildCommand}" IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>
            <Button Content="刷新" Width="80" Height="30" Margin="0,0,10,0" Command="{Binding RefreshCommand}"/>
            <Button Content="关闭" Width="80" Height="30" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
