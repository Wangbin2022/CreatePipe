<Window x:Class="CreatePipe.OfficalSamples.AreaReinforcementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
     Title="面积配筋处理工具" 
        Height="350" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">
    <Window.Resources>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:StatusColorConverter x:Key="StatusColorConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="面积配筋 - 图层与弯钩处理"
                   FontSize="16" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- 说明文字 -->
        <TextBlock Grid.Row="1" 
                   TextWrapping="Wrap"
                   Margin="0,0,0,15"
                   Foreground="#555555">
            此工具将执行以下操作：
            <LineBreak/>
            • 关闭除主方向层外的所有钢筋层
            <LineBreak/>
            • 移除主方向层边界曲线上的弯钩
        </TextBlock>

        <!-- 分隔线 -->
        <Border Grid.Row="2" 
                Height="1" 
                Background="#CCCCCC" 
                Margin="0,0,0,15"/>

        <!-- 状态区域 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,20">
            <!-- 处理状态 -->
            <Border Background="#F5F5F5" 
                    CornerRadius="5" 
                    Padding="10"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="处理状态：" FontWeight="Bold"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               Margin="0,5,0,0"
                               Foreground="{Binding IsProcessing, 
                                    Converter={StaticResource StatusColorConverter}}"/>
                    <ProgressBar IsIndeterminate="{Binding IsProcessing}"
                                 Height="5"
                                 Margin="0,10,0,0"
                                 Visibility="{Binding IsProcessing, 
                                    Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- 结果显示 -->
            <Border Background="#E8F4FD" 
                    CornerRadius="5" 
                    Padding="10"
                    Visibility="{Binding OperationSucceeded, 
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding ResultMessage}" 
                           Foreground="#0066CC"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- 错误显示 -->
            <Border Background="#FDEDEC" 
                    CornerRadius="5" 
                    Padding="10"
                    Visibility="{Binding OperationSucceeded, 
                        Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="#E74C3C"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- 按钮栏 -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="重新处理" 
                    Command="{Binding ProcessCommand}"
                    Width="80"
                    Margin="0,0,10,0"
                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"/>
            <Button Content="关闭" 
                    Command="{Binding CancelCommand}"
                    Width="75"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
