<Window x:Class="CreatePipe.OfficalSamples.DoorOperatorByIdleEvent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
        Title="门构件操作工具" Height="550" Width="700"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 操作按钮样式 -->
        <Style x:Key="OpButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- 选中行样式 -->
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#FFE6F2FF"/>
                    <Setter Property="BorderBrush" Value="#FF3399FF"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#FF2C3E50" Padding="10" Margin="-10,0,-10,10" CornerRadius="0,0,5,5">
            <StackPanel>
                <TextBlock Text="🚪 门构件操作工具" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="基于Revit选中的门进行操作" FontSize="11" Foreground="#FFBDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 信息栏 -->
        <Border Grid.Row="1" Background="#FFF5F5F5" Padding="8" Margin="0,0,0,10" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊 " FontSize="12"/>
                    <TextBlock Text="选中状态：" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SelectedCount}" Foreground="#FF3399FF" FontWeight="Bold" Margin="5,0"/>
                    <TextBlock Text="个门构件被选中"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="⟳ 刷新列表" Command="{Binding LoadDoorsCommand}" 
                            Width="90" Margin="0,0,5,0" Cursor="Hand"/>
                    <Button Content="🔄 刷新选中" Command="{Binding RefreshSelectionCommand}" 
                            Width="90" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 门列表 -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Doors}" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Extended" Margin="0,5"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#FFF9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="族名称" Binding="{Binding FamilyName}" Width="120"/>
                <DataGridTextColumn Header="类型名称" Binding="{Binding TypeName}" Width="120"/>
                <DataGridTextColumn Header="实例名称" Binding="{Binding Name}" Width="100"/>
                <!--<DataGridTextColumn Header="把手方向" Binding="{Binding IsHandFlipped, Converter={StaticResource BoolToHandConverter}}" Width="70"/>
                <DataGridTextColumn Header="开启朝向" Binding="{Binding IsFacingFlipped, Converter={StaticResource BoolToFacingConverter}}" Width="70"/>-->
                <DataGridTextColumn Header="把手方向" Binding="{Binding IsHandFlipped}" Width="70"/>
                <DataGridTextColumn Header="开启朝向" Binding="{Binding IsFacingFlipped}" Width="70"/>
                <DataGridTextColumn Header="状态" Binding="{Binding OrientationInfo}" Width="120"/>
                <DataGridTemplateColumn Header="选中" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=OneWay}" IsEnabled="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage, FallbackValue='就绪'}" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 操作按钮区域 -->
        <Border Grid.Row="4" BorderBrush="#FFE0E0E0" BorderThickness="0,1,0,0" Padding="0,10,0,0">
            <StackPanel>
                <!-- 方向调整组 -->
                <GroupBox Header="🎯 方向调整" Margin="0,0,0,8">
                    <StackPanel>
                        <!-- 把手方向组 -->
                        <Border Background="#FFF8F8F8" Padding="8,5" Margin="5">
                            <StackPanel>
                                <TextBlock Text="把手方向 (Left/Right)" FontWeight="Bold" Margin="0,0,0,5"/>
                                <WrapPanel>
                                    <Button Content="⬅ 左开 (Left)" Command="{Binding MakeLeftCommand}" 
                                            Style="{StaticResource OpButtonStyle}"/>
                                    <Button Content="右开 (Right) ➡" Command="{Binding MakeRightCommand}" 
                                            Style="{StaticResource OpButtonStyle}"/>
                                    <Button Content="🔄 翻转把手" Command="{Binding FlipHandCommand}" 
                                            Style="{StaticResource OpButtonStyle}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- 开启方向组 -->
                        <Border Background="#FFF8F8F8" Padding="8,5" Margin="5,10,5,5">
                            <StackPanel>
                                <TextBlock Text="开启方向 (In/Out)" FontWeight="Bold" Margin="0,0,0,5"/>
                                <WrapPanel>
                                    <Button Content="内开 (In) ⬇" Command="{Binding TurnInCommand}" 
                                            Style="{StaticResource OpButtonStyle}"/>
                                    <Button Content="外开 (Out) ⬆" Command="{Binding TurnOutCommand}" 
                                            Style="{StaticResource OpButtonStyle}"/>
                                    <Button Content="🔄 翻转朝向" Command="{Binding FlipFacingCommand}" 
                                            Style="{StaticResource OpButtonStyle}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- 旋转操作 -->
                        <WrapPanel Margin="5,5,5,0" HorizontalAlignment="Center">
                            <Button Content="⟳ 旋转180度" Command="{Binding RotateCommand}" 
                                    Style="{StaticResource OpButtonStyle}" Width="120"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <!-- 删除操作组 -->
                <GroupBox Header="🗑 删除操作" Margin="0,0,0,8">
                    <WrapPanel Margin="5" HorizontalAlignment="Center">
                        <Button Content="删除选中的门" Command="{Binding DeleteCommand}" 
                                Style="{StaticResource OpButtonStyle}"
                                Background="#FFFFE0E0"/>
                    </WrapPanel>
                </GroupBox>

                <!-- 提示信息 -->
                <TextBlock Text="💡 提示：请在Revit视图中选中要操作的门构件，然后点击上方按钮进行操作" 
                           FontSize="10" Foreground="Gray" Margin="5,0,0,5" TextWrapping="Wrap"/>
                <TextBlock Text="💡 说明：左开/右开、内开/外开的标准可根据实际需求在代码中调整" 
                           FontSize="10" Foreground="Gray" Margin="5,0,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
