<Window x:Class="CreatePipe.OfficalSamples.DatumStyleModificationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
        Title="基准线样式设置" Height="420" Width="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <!-- 样式选项模板 -->
        <DataTemplate x:Key="StyleOptionTemplate">
            <CheckBox IsChecked="{Binding IsChecked}" 
                      Content="{Binding DisplayName}"
                      Margin="5,3"/>
        </DataTemplate>
        <!-- 基准线示意图数据 -->
        <DrawingBrush x:Key="DatumDiagram" Viewport="0,0,1,1" ViewportUnits="RelativeToBoundingBox">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <!-- 基准线主体 -->
                    <GeometryDrawing Brush="Blue" Geometry="M 50,35 L 150,35 M 50,15 L 150,15"/>
                    <!-- 端点圆圈 -->
                    <GeometryDrawing Brush="Blue" Geometry="M 30,25 A 10,10 0 1,0 30,25.01"/>
                    <GeometryDrawing Brush="Blue" Geometry="M 170,25 A 10,10 0 1,0 170,25.01"/>
                    <!-- 弯头示意 -->
                    <!--<PolylineGeometry Points="30,25 80,25 80,35" Pen="Blue"/>
                    <PolylineGeometry Points="170,25 120,25 120,35" Pen="Blue"/>-->
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock Grid.Row="0" Text="基准线样式修改" FontSize="16" FontWeight="Bold" 
                       Margin="0,0,0,15" HorizontalAlignment="Center"/>

            <!-- 选中状态提示 -->
            <Border Grid.Row="1" Background="#FFF3E0" CornerRadius="3" Padding="8,5" Margin="0,0,0,15">
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="#E65100">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedElements}" Value="False">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- 左右端点样式设置区域 -->
            <Grid Grid.Row="2" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左端样式 -->
                <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1" 
                        CornerRadius="5" Padding="10" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="左端样式" FontWeight="Bold" FontSize="14" 
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <CheckBox IsChecked="{Binding LeftEndStyle.ShowBubble}" 
                                  Content="显示气泡" Margin="5,3"/>
                        <CheckBox IsChecked="{Binding LeftEndStyle.AddElbow}" 
                                  Content="添加弯头" Margin="5,3"/>
                        <CheckBox IsChecked="{Binding LeftEndStyle.Use2DExtents}" 
                                  Content="2D范围（视图专用）" Margin="5,3"/>

                        <Separator Margin="0,10"/>
                        <Button Command="{Binding ResetLeftCommand}" 
                                Content="重置" HorizontalAlignment="Right"
                                Width="60" Margin="5,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 示意图 -->
                <Border Grid.Column="1" Width="120" Margin="10,0">
                    <!--<Image Source="{StaticResource DatumDiagram}" Stretch="Uniform"/>-->
                </Border>

                <!-- 右端样式 -->
                <Border Grid.Column="2" BorderBrush="#CCC" BorderThickness="1" 
                        CornerRadius="5" Padding="10" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="右端样式" FontWeight="Bold" FontSize="14" 
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <CheckBox IsChecked="{Binding RightEndStyle.ShowBubble}" 
                                  Content="显示气泡" Margin="5,3"/>
                        <CheckBox IsChecked="{Binding RightEndStyle.AddElbow}" 
                                  Content="添加弯头" Margin="5,3"/>
                        <CheckBox IsChecked="{Binding RightEndStyle.Use2DExtents}" 
                                  Content="2D范围（视图专用）" Margin="5,3"/>

                        <Separator Margin="0,10"/>
                        <Button Command="{Binding ResetRightCommand}" 
                                Content="重置" HorizontalAlignment="Right"
                                Width="60" Margin="5,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 提示信息 -->
            <TextBlock Grid.Row="3" Text="提示：2D范围模式下，基准线端点仅在当前视图中显示；模型范围模式下，端点在所有相关视图中同步" 
                       FontSize="11" Foreground="Gray" 
                       Margin="0,15,0,5" TextWrapping="Wrap"/>

            <!-- 按钮区域 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" 
                        HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Command="{Binding RefreshSelectionCommand}" 
                        Content="刷新选中" Width="80" Height="28" 
                        Margin="0,0,10,0"/>
                <Button Command="{Binding ApplyCommand}" 
                        Content="应用" Width="70" Height="28"
                        IsEnabled="{Binding HasSelectedElements}" 
                        Background="#007ACC" Foreground="White" Margin="0,0,5,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#007ACC"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#CCC"/>
                                    <Setter Property="Foreground" Value="Gray"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Command="{Binding CancelCommand}" 
                        Content="取消" Width="70" Height="28"/>
            </StackPanel>

            <!-- 加载进度提示 -->
            <Border Grid.RowSpan="5" Background="#80FFFFFF" 
                    Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
