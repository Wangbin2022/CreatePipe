<Window x:Class="CreatePipe.OfficalSamples.CreateCurtainWallView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
      Title="幕墙网格编辑器" Height="550" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 创建幕墙面板 -->
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="10">
                    <Label Content="幕墙类型:"/>
                    <ComboBox ItemsSource="{Binding WallTypes}" 
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedWallType}" 
                              Width="150"/>
                </StackPanel>
                <StackPanel Margin="10">
                    <Label Content="视图平面:"/>
                    <ComboBox ItemsSource="{Binding Views}" 
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedView}" 
                              Width="150"/>
                </StackPanel>
                <Button Content="创建幕墙" Command="{Binding CreateWallCommand}" 
                        Margin="10" Width="100" Height="30"/>
                <Button Content="清除基线" Command="{Binding ClearBaselineCommand}" 
                        Margin="10" Width="100" Height="30"/>
            </StackPanel>
        </Border>

        <!-- 幕墙网格显示区域 -->
        <TabControl Grid.Row="1" Margin="5">
            <TabItem Header="网格视图">
                <Border BorderBrush="Black" BorderThickness="1">
                    <ContentControl Content="{Binding CurtainGridDrawing}" />
                </Border>
            </TabItem>
            <TabItem Header="属性视图">
                <!--<PropertyGrid SelectedObject="{Binding GridProperties}" />-->
            </TabItem>
        </TabControl>

        <!-- 操作面板 -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <Label Content="网格操作:"/>
                    <ComboBox ItemsSource="{Binding LineOperations}" 
                              SelectedItem="{Binding SelectedLineOperation}"
                              Width="150" Margin="5"/>
                    <Button Content="执行操作" Command="{Binding ExecuteOperationCommand}" 
                            Margin="5" Width="80"/>
                    <Button Content="重新加载" Command="{Binding ReloadDataCommand}" 
                            Margin="5" Width="80"/>
                    <Button Content="添加竖梃" Command="{Binding AddAllMullionsCommand}" 
                            Margin="5" Width="80"/>
                    <Button Content="删除竖梃" Command="{Binding DeleteAllMullionsCommand}" 
                            Margin="5" Width="80"/>
                    <Button Content="退出" Command="{Binding ExitCommand}" 
                            Margin="5" Width="80"/>
                </StackPanel>
                <StatusBar>
                    <StatusBarItem Content="{Binding OperationStatus}"/>
                </StatusBar>
            </StackPanel>
        </Border>
    </Grid>
</Window>
