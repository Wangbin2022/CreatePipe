<Window x:Class="CreatePipe.OfficalSamples.CircuitOperationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
     Title="电力电路管理" Height="100" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="OperationButton" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" HorizontalAlignment="Center">
            <!-- 创建电路按钮 -->
            <Button Command="{Binding CreateCircuitCommand}"
                    Style="{StaticResource OperationButton}"
                    ToolTip="创建电路"
                    IsEnabled="{Binding CanCreateCircuit}">
                <!--<Image Source="/Resources/CreateCircuit.png" Width="32" Height="32"/>-->
            </Button>

            <!-- 编辑电路按钮 -->
            <Button Command="{Binding EditCircuitCommand}"
                    Style="{StaticResource OperationButton}"
                    ToolTip="编辑电路"
                    IsEnabled="{Binding HasCircuit}">
                <!--<Image Source="/Resources/EditCircuit.png" Width="32" Height="32"/>-->
            </Button>

            <!-- 选择配电盘按钮 -->
            <Button Command="{Binding SelectPanelCommand}"
                    Style="{StaticResource OperationButton}"
                    ToolTip="选择配电盘"
                    IsEnabled="{Binding HasCircuit}">
                <!--<Image Source="/Resources/SelectPanel.png" Width="32" Height="32"/>-->
            </Button>

            <!-- 断开配电盘按钮 -->
            <Button Command="{Binding DisconnectPanelCommand}"
                    Style="{StaticResource OperationButton}"
                    ToolTip="断开配电盘"
                    IsEnabled="{Binding HasPanel}">
                <!--<Image Source="/Resources/DisconnectPanel.png" Width="32" Height="32"/>-->
            </Button>

            <!-- 取消按钮 -->
            <Button Command="{Binding CancelCommand}"
                    Style="{StaticResource OperationButton}"
                    ToolTip="取消">
                <!--<Image Source="/Resources/Cancel.png" Width="32" Height="32"/>-->
            </Button>
        </WrapPanel>

        <!-- 状态提示 -->
        <TextBlock Grid.Row="1" 
                   Text="💡 提示：请选择要执行的操作"
                   FontSize="11"
                   Foreground="Gray"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>

        <!-- 处理中覆盖层 -->
        <Border Background="#CCFFFFFF" 
                Grid.RowSpan="2"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="处理中..." 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
