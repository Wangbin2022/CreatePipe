<Window x:Class="CreatePipe.OfficalSamples.AutoTagRoomsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="自动房间标记" 
        Height="550" Width="750"
        WindowStartupLocation="CenterScreen"
              xmlns:conv="clr-namespace:CreatePipe.Form.Converters">
    <Window.Resources>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:BooleanToResultTextConverter x:Key="BooleanToResultTextConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="自动房间标记工具"
                   FontSize="18" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- 选项区域 -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Label Content="选择楼层" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding Levels}"
                          SelectedItem="{Binding SelectedLevel}"
                          DisplayMemberPath="DisplayText"
                          Height="25"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Label Content="标记类型" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding TagTypes}"
                          SelectedItem="{Binding SelectedTagType}"
                          DisplayMemberPath="Name"
                          Height="25"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10,0,0,10">
                <Button Content="刷新" 
                        Command="{Binding RefreshCommand}"
                        Width="60"
                        Margin="0,0,5,0"/>
                <Button Content="全选" 
                        Command="{Binding SelectAllCommand}"
                        Width="60"
                        Margin="0,0,5,0"/>
                <Button Content="清空" 
                        Command="{Binding DeselectAllCommand}"
                        Width="60"/>
            </StackPanel>
        </Grid>

        <!-- 房间列表 -->
        <GroupBox Grid.Row="2" Header="房间列表" Margin="0,0,0,10">
            <ListView ItemsSource="{Binding Rooms}"
                      SelectedItem="{Binding SelectedRoom}"
                      Height="200">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="选择" Width="50">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked}" 
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="房间编号" Width="100" 
                                        DisplayMemberBinding="{Binding Number}"/>
                        <GridViewColumn Header="房间名称" Width="150" 
                                        DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="面积(m²)" Width="80" 
                                        DisplayMemberBinding="{Binding Area, StringFormat={}{0:F2}}"/>
                        <GridViewColumn Header="标记数量" Width="80" 
                                        DisplayMemberBinding="{Binding TagCount}"/>
                        <GridViewColumn Header="状态" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding HasTag, Converter={StaticResource BooleanToResultTextConverter}}"
                                               Foreground="{Binding HasTag, Converter={StaticResource BooleanToBrushConverter}}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <!-- 统计信息 -->
        <Border Grid.Row="3" 
                Background="#F5F5F5" 
                CornerRadius="5"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding TaggingResult}" 
                           FontWeight="Bold"
                           Foreground="#2E7032"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="#555555"
                           FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- 按钮栏 -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" 
                    Content="自动标记所有选中房间"
                    Command="{Binding AutoTagCommand}"
                    IsEnabled="{Binding CanAutoTag}"
                    Width="180"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#5B9BD5"
                    Foreground="White"
                    FontWeight="Bold"/>

            <Button Grid.Column="2"
                    Content="关闭"
                    Command="{Binding CancelCommand}"
                    Width="75"
                    Height="35"
                    IsCancel="True"/>
        </Grid>

        <!-- 加载遮罩 -->
        <Border Grid.RowSpan="6"
                Background="#80000000"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="250" Height="20"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
