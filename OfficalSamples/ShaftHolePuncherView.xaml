<Window x:Class="CreatePipe.OfficalSamples.ShaftHolePuncherView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
   Title="竖井洞口创建器" Height="500" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 提示文字 -->
        <TextBlock Grid.Row="0" 
                   Text="💡 提示：鼠标左键点击绘制曲线，右键闭合曲线"
                   Foreground="Gray"
                   Margin="0,0,0,10"/>

        <!-- 绘图区域 -->
        <Border Grid.Row="1" 
                BorderBrush="Gray" 
                BorderThickness="1"
                Background="White"
                CornerRadius="3">
            <Grid>
                <!--<Image x:Name="PreviewImage" 
                       Stretch="Fill"
                       MouseDown="PreviewImage_MouseDown"
                       MouseMove="PreviewImage_MouseMove"/>-->

                <!-- 缩放控制 -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Top"
                            Margin="5">
                    <TextBlock Text="缩放：" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding ScaleOptions}"
                              SelectedItem="{Binding Scale}"
                              Width="50"
                              Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 方向选择和按钮区域 -->
        <Grid Grid.Row="2" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="方向：" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" 
                      ItemsSource="{Binding DirectionOptions}"
                      SelectedItem="{Binding Direction}"
                      Width="80"
                      Margin="5,0"/>

            <Button Grid.Column="2" 
                    Content="清空" 
                    Command="{Binding CleanCommand}"
                    Width="70" Margin="5"
                    IsEnabled="{Binding CanExecute}"/>
            <Button Grid.Column="3" 
                    Content="创建" 
                    Command="{Binding CreateCommand}"
                    Width="70" Margin="5"
                    Background="LightGreen"
                    IsEnabled="{Binding CanExecute}"/>
            <Button Grid.Column="4" 
                    Content="取消" 
                    Command="{Binding CancelCommand}"
                    Width="70" Margin="5"
                    IsCancel="True"/>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="状态：就绪" Foreground="Gray"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 处理中覆盖层 -->
        <Border Background="#CCFFFFFF" 
                Grid.RowSpan="4"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="创建中..." 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       FontSize="16"/>
        </Border>
    </Grid>
</Window>
