<Window x:Class="CreatePipe.OfficalSamples.ZoneEditorMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
Title="Add Spaces and Zones" Height="500" Width="450"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Level:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding Levels}" 
                      SelectedItem="{Binding CurrentLevel}"
                      DisplayMemberPath="Name"
                      Width="250"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Spaces">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView ItemsSource="{Binding Spaces}" Grid.Row="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Space" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Zone" DisplayMemberBinding="{Binding ZoneName}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Button Content="Create Spaces" 
                            Command="{Binding CreateSpacesCommand}"
                            Grid.Row="1" Margin="0,5,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="Zones">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView ItemsSource="{Binding Zones}" 
                              SelectedItem="{Binding SelectedZone}"
                              Grid.Row="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Phase}" FontSize="10" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,5,0,0">
                        <Button Content="Create Zone" Command="{Binding CreateZoneCommand}" Width="100" Margin="0,0,5,0"/>
                        <Button Content="Edit Zone" Command="{Binding EditZoneCommand}" Width="100"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" IsDefault="True" Width="75" Margin="0,0,5,0"
                    Click="OkButton_Click"/>
            <Button Content="Cancel" IsCancel="True" Width="75"/>
        </StackPanel>
    </Grid>
</Window>
