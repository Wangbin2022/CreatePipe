<Window x:Class="CreatePipe.OfficalSamples.FloorThicknessView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
        Title="楼板厚度批量修改工具"  Height="700"  Width="900"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="CanResize"  MinHeight="600"  MinWidth="800"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <!-- 转换器 -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:ThicknessToDisplayConverter x:Key="ThicknessToDisplay"/>
        <local:RatioToColorConverter x:Key="RatioToColor"/>
        <local:SelectedBackgroundConverter x:Key="SelectedBackgroundConverter"/>
        <local:BoolToProcessingColorConverter  x:Key="BoolToProcessingColor"/>

        <!-- 数据模板：层信息行 -->
        <DataTemplate x:Key="LayerTemplate">
            <Border BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1" 
                    Padding="5" Background="{Binding IsSelected, Converter={StaticResource SelectedBackgroundConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" 
                              VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding LayerName}" 
                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="{Binding LayerFunction}" 
                               VerticalAlignment="Center" FontSize="11" Foreground="#FF666666"/>
                    <TextBlock Grid.Column="3" Text="{Binding OriginalThicknessDisplay}" 
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               Margin="0,0,10,0"/>
                    <Border Grid.Column="4" Background="#FFF0F8FF" CornerRadius="3" 
                            Padding="5,2" Margin="2">
                        <TextBlock Text="{Binding NewThicknessDisplay}" 
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   FontWeight="Bold" Foreground="#FF007ACC"/>
                    </Border>
                    <TextBlock Grid.Column="5" Text="{Binding ThicknessRatio, StringFormat=F2x}" 
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               FontSize="11" Foreground="{Binding ThicknessRatio, Converter={StaticResource RatioToColor}}" />
                    <Button Grid.Column="6" Content="重置" Width="60" Height="22"
                            Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Path=DataContext.ResetLayerCommand}"
                            CommandParameter="{Binding}" FontSize="10"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#FF2C3E50" 
                Padding="10" Margin="-10,-10,-10,5" CornerRadius="0,0,5,5">
            <StackPanel>
                <TextBlock Text="楼板厚度批量修改工具" FontSize="16" 
                           FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="批量修改选中楼板的结构层厚度" FontSize="11" 
                           Foreground="#FFBDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 左侧：选中的楼板列表 -->
        <GroupBox Header="📋 选中的楼板" Grid.Row="1" Grid.Column="0" Margin="0,5,5,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FFF5F5F5" Padding="5" Margin="0,0,0,5"
                        CornerRadius="3">
                    <TextBlock Text="{Binding SelectedFloors.Count, StringFormat='共 {0} 个楼板'}" 
                               FontSize="11" Foreground="#FF666666"/>
                </Border>

                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding SelectedFloors}" 
                         SelectedItem="{Binding SelectedFloor}"
                         DisplayMemberPath="DisplayName"
                         SelectionMode="Single"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="Margin" Value="2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FFE8F0FE"/>
                                    <Setter Property="BorderBrush" Value="#FF007ACC"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                    <Button Content="🔄 刷新" Command="{Binding RefreshCommand}"
                            Width="70" Height="28" Margin="0,0,5,0"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 分隔线 -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Width="3" 
                      HorizontalAlignment="Stretch" Background="#FFD9D9D9"/>

        <!-- 右侧：层信息和操作区域 -->
        <Grid Grid.Row="1" Grid.Column="2" Margin="5,5,0,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 当前楼板信息 -->
            <Border Grid.Row="0" Background="#FFF5F5F5" Padding="8" CornerRadius="5" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock FontWeight="Bold" FontSize="12">
                        <Run Text="当前楼板类型: "/>
                        <Run Text="{Binding SelectedFloor.FloorTypeName, FallbackValue=--}" 
                             Foreground="#FF007ACC"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Margin="0,5,0,0">
                        <Run Text="层数: "/>
                        <Run Text="{Binding SelectedFloor.LayerCount, FallbackValue=--}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 修改参数设置 -->
            <GroupBox Grid.Row="1" Header="⚙️ 修改参数" Margin="0,0,0,10">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="乘法因子:" 
                           VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                        <TextBox Text="{Binding MultiplyFactor, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="80" Margin="0,0,10,0"/>
                        <Button Content="2x" Command="{Binding SetMultiplyFactorCommand}" 
                                CommandParameter="2" Width="40" Margin="2"/>
                        <Button Content="5x" Command="{Binding SetMultiplyFactorCommand}" 
                                CommandParameter="5" Width="40" Margin="2"/>
                        <Button Content="10x" Command="{Binding SetMultiplyFactorCommand}" 
                                CommandParameter="10" Width="40" Margin="2"/>
                    </StackPanel>

                    <Label Grid.Row="1" Grid.Column="0" Content="增加值 (英尺):" 
                           VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" 
                             Text="{Binding AddValue, UpdateSourceTrigger=PropertyChanged}" 
                             Width="120" HorizontalAlignment="Left"/>

                    <CheckBox Grid.Row="2" Grid.ColumnSpan="2" 
                              Content="仅应用于选中的层" 
                              IsChecked="{Binding ApplyToSelectedOnly}"
                              Margin="0,5,0,5"/>

                    <Border Grid.Row="3" Grid.ColumnSpan="2" 
                            Background="#FFFFF8E8" Padding="8" CornerRadius="3">
                        <TextBlock Text="{Binding ThicknessSummary}" 
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#FFD2691E"/>
                    </Border>
                </Grid>
            </GroupBox>

            <!-- 层列表 -->
            <GroupBox Grid.Row="2" Header="📊 结构层列表" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 列表头 -->
                    <Border Grid.Row="0" Background="#FFE8F0FE" Padding="5" 
                            BorderBrush="#FFD9D9D9" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0" 
                                      IsChecked="{Binding ElementName=SelectAllCheckBox, Path=IsChecked}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="层名称" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="功能" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="原始厚度" FontWeight="Bold" 
                                       HorizontalAlignment="Right" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="4" Text="新厚度" FontWeight="Bold" 
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="变化比例" FontWeight="Bold" 
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="操作" FontWeight="Bold" 
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 数据列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PreviewLayers}" 
                                      ItemTemplate="{StaticResource LayerTemplate}"/>
                    </ScrollViewer>
                </Grid>
            </GroupBox>

            <!-- 操作按钮 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="✅ 全选" Command="{Binding SelectAllLayersCommand}"
                        Margin="0,0,5,0" Padding="15,5"/>
                <Button Content="❌ 全不选" Command="{Binding DeselectAllLayersCommand}"
                        Margin="0,0,15,0" Padding="15,5"/>
                <Button Content="🔄 重置当前" Command="{Binding ResetCommand}"
                        Margin="0,0,10,0" Padding="15,5"/>
                <Button Content="💾 应用修改" Command="{Binding ApplyChangesCommand}"
                        Background="#FF007ACC" Foreground="White" 
                        Padding="20,8" FontWeight="Bold"
                        IsDefault="True"/>
                <Button Content="✗ 取消" IsCancel="True" 
                        Margin="10,0,0,0" Padding="15,5"/>
            </StackPanel>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Grid.ColumnSpan="3" Margin="0,5,0,0"
                   Background="#FFF0F0F0" Height="30">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Border Width="8" Height="8" CornerRadius="4" 
                            Background="{Binding IsProcessing, 
                                       Converter={StaticResource BoolToProcessingColor}}"
                            Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               FontSize="11" Foreground="#FF333333"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- 加载遮罩 -->
        <Border Grid.RowSpan="3" Grid.ColumnSpan="3" 
                Background="#CCFFFFFF" 
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="White" Padding="30,20" CornerRadius="8" >
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="15"
                                     Foreground="#FF007ACC"/>
                        <TextBlock Text="处理中..." Margin="0,10,0,0" 
                                   HorizontalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
