<Window x:Class="CreatePipe.OfficalSamples.PhaseSelectorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
    Title="阶段选择器" Height="400" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 阶段类型选择 -->
        <GroupBox Grid.Row="0" Header="阶段类型" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <RadioButton Content="创建阶段 (Created)"
                             IsChecked="{Binding IsCreatedSelected}"
                             Margin="0,5"/>
                <RadioButton Content="拆除阶段 (Demolished)"
                             IsChecked="{Binding IsDemolishedSelected}"
                             Margin="0,5"/>
            </StackPanel>
        </GroupBox>

        <!-- 阶段多选列表 -->
        <GroupBox Grid.Row="1" Header="选择阶段" Margin="0,0,0,10">
            <DockPanel Margin="5">
                <StackPanel DockPanel.Dock="Bottom" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            Margin="0,5,0,0">
                    <Button Content="全选" 
                            Command="{Binding SelectAllCommand}"
                            Width="60" Margin="5"/>
                    <Button Content="清空" 
                            Command="{Binding DeselectAllCommand}"
                            Width="60" Margin="5"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Phases}"
                         SelectionMode="Extended"
                         Height="150">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}"
                                      IsChecked="{Binding IsSelected}"
                                      Margin="5,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </GroupBox>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="确定" 
                    Command="{Binding OkCommand}"
                    Width="75" Margin="5" IsDefault="True"/>
            <Button Content="取消" 
                    Command="{Binding CancelCommand}"
                    Width="75" Margin="5" IsCancel="True"/>
        </StackPanel>

        <!-- 处理中覆盖层 -->
        <Border Background="#CCFFFFFF" 
                Grid.RowSpan="4"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="筛选中..." 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       FontSize="16"/>
        </Border>
    </Grid>
</Window>
