<Window x:Class="CreatePipe.OfficalSamples.JournalingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
      Title="日志墙体创建工具" 
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <!-- 墙体类型转换器 -->
        <DataTemplate x:Key="WallTypeTemplate">
            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
        </DataTemplate>

        <!-- 标高转换器 -->
        <DataTemplate x:Key="LevelTemplate">
            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="5" Margin="0,0,0,15" Padding="10">
            <TextBlock Text="📝 日志墙体创建工具 - 支持操作重放" 
                       FontSize="14" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- 墙体类型 -->
        <Grid Grid.Row="1" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="墙体类型:" VerticalAlignment="Center" FontWeight="Bold"/>
            <ComboBox Grid.Column="1" 
                      ItemsSource="{Binding WallTypes}"
                      SelectedItem="{Binding SelectedWallType}"
                      DisplayMemberPath="Name"
                      IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"/>
        </Grid>

        <!-- 标高 -->
        <Grid Grid.Row="2" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="标高:" VerticalAlignment="Center" FontWeight="Bold"/>
            <ComboBox Grid.Column="1" 
                      ItemsSource="{Binding Levels}"
                      SelectedItem="{Binding SelectedLevel}"
                      DisplayMemberPath="Name"
                      IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"/>
        </Grid>

        <!-- 位置信息分组 -->
        <GroupBox Grid.Row="3" Header="📐 墙体位置线" Margin="0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 起点 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="起点:" 
                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="X:" 
                           VerticalAlignment="Center" Margin="5,0"/>
                <TextBox Grid.Row="0" Grid.Column="2" 
                         Text="{Binding StartX, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Y:" 
                           VerticalAlignment="Center" Margin="5,0"/>
                <TextBox Grid.Row="0" Grid.Column="4" 
                         Text="{Binding StartY, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" HorizontalAlignment="Left"/>

                <!-- 终点 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="终点:" 
                           VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="X:" 
                           VerticalAlignment="Center" Margin="5,10,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="2" 
                         Text="{Binding EndX, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="Y:" 
                           VerticalAlignment="Center" Margin="5,10,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="4" 
                         Text="{Binding EndY, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" HorizontalAlignment="Left" Margin="0,10,0,0"/>
            </Grid>
        </GroupBox>

        <!-- 日志信息提示 -->
        <Border Grid.Row="4" 
                Background="{Binding UseJournalData, Converter={StaticResource BooleanToBrushConverter}, 
                                 ConverterParameter='#E8F5E9;#FFF3E0'}"
                CornerRadius="5" Padding="10" Margin="0,10" Height="60">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ️ " FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           TextWrapping="Wrap" VerticalAlignment="Center"
                           Foreground="{Binding UseJournalData, Converter={StaticResource BooleanToBrushConverter}, 
                                                ConverterParameter='#2E7D32;#E65100'}"/>
            </StackPanel>
        </Border>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="取消" 
                    Command="{Binding CancelCommand}"
                    Width="80" Height="32" Margin="5"
                    Background="#E0E0E0"/>
            <Button Content="✅ 创建墙体" 
                    Command="{Binding CreateWallCommand}"
                    Width="100" Height="32" Margin="5"
                    Background="#27AE60" Foreground="White"
                    IsEnabled="{Binding CanCreateWall}"/>
        </StackPanel>
    </Grid>
</Window>
