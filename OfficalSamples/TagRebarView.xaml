<Window x:Class="CreatePipe.OfficalSamples.TagRebarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
     Title="钢筋标记工具" 
        Height="500" 
        Width="600"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="CanResize"
        MinHeight="400" 
        MinWidth="500"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <!-- 转换器 -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <!--<local:EffectResources x:Key="EffectResources"/>-->

        <!-- 列表项样式 -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="5,3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 分组框样式 -->
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#FFD9D9D9"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- 按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFCCCCCC"/>
                    <Setter Property="Foreground" Value="#FF666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 标题样式 -->
        <Style x:Key="SectionTitleStyle" TargetType="Label">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Foreground" Value="#FF333333"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <Border Grid.Row="0" Background="#FFF0F0F0" Padding="10" Margin="0,0,0,10" 
                CornerRadius="5">
            <StackPanel>
                <TextBlock Text="钢筋标记工具" FontSize="16" FontWeight="Bold" 
                           Foreground="#FF007ACC"/>
                <TextBlock Text="为选中的钢筋创建标记或文字注释" FontSize="11" 
                           Foreground="#FF666666" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：选中的钢筋列表 -->
            <GroupBox Header="选中的钢筋" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 统计信息 -->
                    <Border Grid.Row="0" Background="#FFF5F5F5" Padding="5" Margin="0,0,0,5"
                            CornerRadius="3">
                        <TextBlock Text="{Binding SelectedRebars.Count, StringFormat='共 {0} 个钢筋'}" 
                                   FontSize="11" Foreground="#FF666666"/>
                    </Border>

                    <!-- 钢筋列表 -->
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding SelectedRebars}" 
                             SelectedItem="{Binding SelectedRebar}"
                             SelectionMode="Extended"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 指示图标 -->
                                    <Border Grid.Column="0" Width="24" Height="24" 
                                            Background="#FFE8F0FE" CornerRadius="12"
                                            Margin="0,0,8,0">
                                        <TextBlock Text="⚡" HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center" FontSize="12"/>
                                    </Border>

                                    <!-- 钢筋信息 -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding DisplayName}" 
                                                   FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding RebarType}" 
                                                   FontSize="10" Foreground="#FF888888"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 操作提示 -->
                    <TextBlock Grid.Row="2" Text="提示: 可多选钢筋 (Ctrl+单击)" 
                               FontSize="10" Foreground="#FF888888" 
                               Margin="0,5,0,0" HorizontalAlignment="Center"/>
                </Grid>
            </GroupBox>

            <!-- 分隔线 -->
            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch" 
                          Background="#FFD9D9D9"/>

            <!-- 右侧：操作区域 -->
            <GroupBox Header="操作选项" Grid.Column="2">
                <StackPanel Margin="5">
                    <!-- 钢筋信息显示 -->
                    <Border Background="#FFF5F5F5" Padding="8" Margin="0,0,0,15"
                            CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="当前选中" FontWeight="Bold" FontSize="11"
                                       Foreground="#FF666666"/>
                            <TextBlock Margin="0,5,0,0">
                                <Run Text="ID: "/>
                                <Run Text="{Binding SelectedRebar.Id.IntegerValue, 
                                              Mode=OneWay, FallbackValue=--}" 
                                     FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="类型: "/>
                                <Run Text="{Binding SelectedRebar.RebarType, 
                                              Mode=OneWay, FallbackValue=--}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 标记选项 -->
                    <Label Style="{StaticResource SectionTitleStyle}" Content="标记选项"/>

                    <Border Background="#FFF9F9F9" Padding="8" Margin="0,0,0,10"
                            CornerRadius="5">
                        <StackPanel>
                            <CheckBox Content="带引线" IsChecked="{Binding HasLeader}" 
                                      Margin="0,5" FontSize="12"/>

                            <Separator Margin="0,8"/>

                            <Label Content="标记方向:" FontSize="11" 
                                   FontWeight="SemiBold" Padding="0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <RadioButton Content="水平" 
                                             IsChecked="{Binding IsHorizontalOrientation}"
                                             GroupName="Orientation"
                                             Margin="0,0,15,0"/>
                                <RadioButton Content="垂直" 
                                             IsChecked="{Binding IsVerticalOrientation}"
                                             GroupName="Orientation"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 操作按钮 -->
                    <Label Style="{StaticResource SectionTitleStyle}" Content="执行操作"/>

                    <StackPanel Margin="0,5">
                        <Button Content="🏷️ 创建钢筋标记" 
                                Command="{Binding CreateTagCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="35"
                                HorizontalAlignment="Stretch">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Content="📝 创建文字注释" 
                                Command="{Binding CreateTextCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="35"
                                Margin="0,8,0,0"
                                Background="#FF6B6B6B"
                                HorizontalAlignment="Stretch">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>        
                        </Button>
                    </StackPanel>

                    <!-- 说明信息 -->
                    <Border Background="#FFFFF8E8" Padding="8" Margin="0,15,0,0"
                            CornerRadius="5" BorderBrush="#FFFFD700" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="💡 说明" FontWeight="Bold" 
                                       FontSize="11" Margin="0,0,0,5"/>
                            <TextBlock Text="• 标记将放置在钢筋的第一个端点"
                                       FontSize="10" Foreground="#FF666666"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="• 文字注释会显示钢筋的名称和类别"
                                       FontSize="10" Foreground="#FF666666"
                                       TextWrapping="Wrap" Margin="0,3,0,0"/>
                            <TextBlock Text="• 所有操作都支持撤销 (Ctrl+Z)"
                                       FontSize="10" Foreground="#FF666666"
                                       TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Margin="0,10,0,0" 
                   Background="#FFF0F0F0" Height="30">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Border Width="8" Height="8" CornerRadius="4" 
                            Background="{Binding IsProcessing}"
                            Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               FontSize="11" Foreground="#FF333333"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- 底部按钮区域 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="↻ 刷新" Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="80" Height="30"/>
            <Button Content="✓ 完成" IsDefault="True" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="80" Height="30"
                    Click="CloseButton_Click"/>
            <Button Content="✗ 取消" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="80" Height="30"/>
        </StackPanel>

        <!-- 加载遮罩层 -->
        <Border Grid.RowSpan="4" 
                Background="#CCFFFFFF" 
                Visibility="{Binding IsProcessing, 
                           Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" 
                        VerticalAlignment="Center">
                <Border Background="White" Padding="20,15" CornerRadius="8">
                    <!--<Border Background="White" Padding="20,15" CornerRadius="8"
                        Effect="{StaticResource DropShadowEffect}">-->
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="15"
                                     Foreground="#FF007ACC"/>
                        <TextBlock Text="{Binding StatusMessage}" 
                                   Margin="0,10,0,0" 
                                   HorizontalAlignment="Center"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
