<Window x:Class="CreatePipe.OfficalSamples.ViewSheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
  Title="视图/图纸集管理器"   Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinHeight="400" MinWidth="500"
         xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <!-- 视图项模板 -->
        <DataTemplate x:Key="ViewSheetItemTemplate">
            <StackPanel Orientation="Horizontal" Margin="2">
                <CheckBox IsChecked="{Binding IsSelected}" 
                          VerticalAlignment="Center"
                          Width="20"/>
                <TextBlock Text="{Binding DisplayName}" 
                           Margin="5,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 标题栏区域 -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="视图/图纸集名称:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox ItemsSource="{Binding ViewSheetSetNames}" 
                      SelectedItem="{Binding SelectedSetName, Mode=TwoWay}"
                      Width="200"
                      IsEnabled="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
        </StackPanel>

        <!-- 进度指示器 -->
        <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="3" 
                     IsIndeterminate="{Binding IsProcessing}"
                     Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"
                     Margin="0,0,0,5"/>

        <!-- 视图/图纸列表 -->
        <GroupBox Grid.Row="2" Grid.ColumnSpan="2" Header="可用的视图和图纸" Margin="0,5">
            <Grid>
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding ViewSheetItems}"
                                  ItemTemplate="{StaticResource ViewSheetItemTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 空状态提示 -->
                <TextBlock Text="没有可用的视图或图纸"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding ViewSheetItems.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
            </Grid>
        </GroupBox>

        <!-- 显示过滤选项 -->
        <GroupBox Grid.Row="3" Grid.Column="0" Header="显示选项" Margin="0,0,10,10">
            <StackPanel Orientation="Horizontal" Margin="10">
                <CheckBox Content="视图" IsChecked="{Binding ShowViews}" Margin="0,0,15,0"/>
                <CheckBox Content="图纸" IsChecked="{Binding ShowSheets}"/>
            </StackPanel>
        </GroupBox>

        <!-- 操作按钮区域 -->
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button Content="全选" Command="{Binding CheckAllCommand}" Width="75" Margin="0,0,5,0"/>
            <Button Content="全不选" Command="{Binding CheckNoneCommand}" Width="75" Margin="0,0,10,0"/>
        </StackPanel>

        <!-- 管理按钮区域 -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <WrapPanel Margin="0,0,0,10">
                <Button Content="保存" Command="{Binding SaveCommand}" Width="75" Margin="0,0,5,0"/>
                <Button Content="另存为..." Command="{Binding SaveAsCommand}" Width="75" Margin="0,0,5,0"/>
                <Button Content="恢复" Command="{Binding RevertCommand}" Width="75" Margin="0,0,5,0"/>
                <Button Content="重命名" Command="{Binding RenameCommand}" Width="75" Margin="0,0,5,0"/>
                <Button Content="删除" Command="{Binding DeleteCommand}" Width="75" Margin="0,0,5,0"/>
            </WrapPanel>

            <WrapPanel HorizontalAlignment="Right">
                <Button Content="确定" Command="{Binding OkCommand}" Width="75" Margin="0,0,5,0" IsDefault="True"/>
                <Button Content="取消" Command="{Binding CancelCommand}" Width="75" IsCancel="True"/>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>
