<Window x:Class="CreatePipe.OfficalSamples.InPlaceFamilyAnalyzerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.OfficalSamples"
      Title="内建族分析器 - 分析模型查看器" 
        Height="700" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <!-- 属性分组样式 -->
        <Style x:Key="PropertyGroupStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- 编辑器显示模板 -->
        <DataTemplate x:Key="ReadOnlyTextTemplate">
            <TextBlock Text="{Binding}" 
                       VerticalAlignment="Center"
                       Background="#F5F5F5"
                       Padding="5,3"/>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" 
                Background="#2C3E50" 
                CornerRadius="5" 
                Margin="0,0,0,10"
                Padding="10">
            <TextBlock Text="🔍 内建族分析模型查看器" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </Border>

        <!-- 左侧：属性面板 -->
        <GroupBox Grid.Row="1" Grid.Column="0" 
                  Header="📋 实例属性" 
                  Style="{StaticResource PropertyGroupStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="5">
                    <!-- 标识信息 -->
                    <GroupBox Header="标识信息" Margin="0,0,0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID：" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedMemberProperties.Id}" Margin="5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="名称：" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedMemberProperties.Name}" Margin="5"/>
                        </Grid>
                    </GroupBox>

                    <!-- 类别信息 -->
                    <GroupBox Header="类别信息" Margin="0,0,0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="族：" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedMemberProperties.Family}" Margin="5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="类型：" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedMemberProperties.Type}" Margin="5"/>
                        </Grid>
                    </GroupBox>

                    <!-- 结构信息 -->
                    <GroupBox Header="结构信息" Margin="0,0,0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="结构类型：" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedMemberProperties.StructuralType}" Margin="5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="结构用途：" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedMemberProperties.StructuralUsage}" Margin="5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="材料类型：" FontWeight="Bold" Margin="5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedMemberProperties.MaterialType}" Margin="5"/>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>

        <!-- 右侧：3D视图面板 -->
        <GroupBox Grid.Row="1" Grid.Column="1" 
                  Header="🔬 分析模型视图" 
                  Style="{StaticResource PropertyGroupStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 工具栏 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                    <Button Content="🔄 重置" 
                            Command="{Binding ResetViewCommand}"
                            Margin="2"
                            Padding="8,3"/>
                    <Separator Width="10"/>
                    <TextBlock Text="旋转:" VerticalAlignment="Center" Margin="5,0"/>
                    <Button Content="↺ X" 
                            Command="{Binding RotateXCommand}" 
                            CommandParameter="True"
                            Margin="2"
                            Width="40"/>
                    <Button Content="↻ X" 
                            Command="{Binding RotateXCommand}" 
                            CommandParameter="False"
                            Margin="2"
                            Width="40"/>
                    <Button Content="↺ Y" 
                            Command="{Binding RotateYCommand}" 
                            CommandParameter="True"
                            Margin="2"
                            Width="40"/>
                    <Button Content="↻ Y" 
                            Command="{Binding RotateYCommand}" 
                            CommandParameter="False"
                            Margin="2"
                            Width="40"/>
                    <Button Content="↺ Z" 
                            Command="{Binding RotateZCommand}" 
                            CommandParameter="True"
                            Margin="2"
                            Width="40"/>
                    <Button Content="↻ Z" 
                            Command="{Binding RotateZCommand}" 
                            CommandParameter="False"
                            Margin="2"
                            Width="40"/>
                </StackPanel>

                <!-- 3D视图区域 -->
                <Border Grid.Row="1" 
                        BorderBrush="#CCCCCC" 
                        BorderThickness="1" 
                        CornerRadius="3"
                        Background="#FAFAFA">
                    <Grid>
                        <!--<local:AnalyticalModelViewer                             DataContext="{Binding AnalyticalModelViewModel}"/>-->

                        <!-- 加载遮罩 -->
                        <Border Background="#CCFFFFFF" 
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar IsIndeterminate="True" Width="150" Height="15"/>
                                <TextBlock Text="加载中..." Margin="0,10" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </GroupBox>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
