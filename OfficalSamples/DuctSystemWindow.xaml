<Window x:Class="CreatePipe.OfficalSamples.DuctSystemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       Title="自动风管系统创建" 
        Height="650" Width="800"
        WindowStartupLocation="CenterScreen"
      xmlns:conv="clr-namespace:CreatePipe.Form.Converters">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="风管系统自动布线工具"
                   FontSize="18" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：构件选择 -->
            <GroupBox Header="构件选择" Grid.Column="0">
                <StackPanel Margin="10">
                    <Label Content="送风设备" FontWeight="Bold"/>
                    <Border Background="#E8F4FD" CornerRadius="3" Padding="5" Margin="0,0,0,10">
                        <TextBlock Text="{Binding SelectedEquipment.Name, FallbackValue='未选择设备的，点击右侧按钮拾取'}"/>
                    </Border>

                    <Label Content="末端设备" FontWeight="Bold" Margin="0,10,0,0"/>
                    <ListBox ItemsSource="{Binding SelectedTerminals}" 
                             SelectedItem="{Binding SelectedTerminal}"
                             Height="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="（最多选择2个末端）" 
                               FontSize="11" 
                               Foreground="Gray"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- 右侧：操作区域 -->
            <GroupBox Header="操作" Grid.Column="2">
                <StackPanel Margin="10">
                    <Label Content="1. 选择构件" FontWeight="Bold"/>
                    <Button Content="从模型拾取设备" 
                            Command="{Binding SelectFromModelCommand}"
                            Margin="0,5"
                            Height="30"/>

                    <Label Content="2. 风管设置" FontWeight="Bold" Margin="0,15,0,0"/>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="风管类型ID:" Grid.Column="0"/>
                        <TextBox Text="{Binding DuctTypeIdInput}" Grid.Column="1"/>
                    </Grid>

                    <Label Content="3. 可用构件" FontWeight="Bold" Margin="0,15,0,0"/>
                    <ListBox ItemsSource="{Binding AvailableElements}"
                             SelectedItem="{Binding SelectedAvailableItem}"
                             Height="100">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Button Content="添加为末端" 
                                Command="{Binding AddTerminalCommand}"
                                Width="100"/>
                        <Button Content="移除选中的末端" 
                                Command="{Binding RemoveTerminalCommand}"
                                Margin="5,0,0,0"
                                Width="120"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- 日志区域 -->
        <GroupBox Grid.Row="2" Header="处理日志" Margin="0,0,0,10">
            <ListBox ItemsSource="{Binding LastResult.LogMessages}"
                     Background="#1E1E1E"
                     Foreground="#D4D4D4"
                     FontFamily="Consolas"
                     FontSize="11"
                     Height="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- 按钮栏 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="开始创建"
                    Command="{Binding CreateSystemCommand}"
                    IsEnabled="{Binding CanCreateSystem}"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#5B9BD5"
                    Foreground="White"
                    FontWeight="Bold"/>
            <Button Content="关闭"
                    Command="{Binding CancelCommand}"
                    Width="75"
                    Height="35"
                    IsCancel="True"/>
        </StackPanel>

        <!-- 加载遮罩 -->
        <Border Grid.RowSpan="4"
                Background="#80000000"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="250" Height="20"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
