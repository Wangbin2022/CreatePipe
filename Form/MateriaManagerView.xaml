<Window x:Class="CreatePipe.Form.MaterialManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.Form"
        mc:Ignorable="d"
        Title="材质管理器" Height="450" Width="600"
       Topmost="True"
       WindowStartupLocation="Manual" Left="30" Top="300" ResizeMode="CanMinimize"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters"
       xmlns:bv="clr-namespace:CreatePipe.Form.Behaviors">
    <Grid Margin="5">
        <Grid.Resources>
            <conv:IntToStringConverter x:Key="IntToStringConverter"/>
            <conv:RevitColorConverter x:Key="colorConverter"/>
            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <conv:BackgroundToForegroundConverter  x:Key="BackgroundToForegroundConverter"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <Grid  >
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBox Width="230"  Margin="5"
  bv:TextBoxBehavior.TextChangedCommand="{Binding QueryElementCommand}" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="{Binding Collection.Count,UpdateSourceTrigger=PropertyChanged,Converter={StaticResource IntToStringConverter}}" VerticalAlignment="Center"/>
                <Button Width="80" Margin="5" Content="新建材质" Command="{Binding NewMaterialCommand}" />
                <Button Width="80" Margin="5" Content="删除选中材质" Command="{Binding DeleteElementsCommand}"
                        CommandParameter="{Binding SelectedItems, ElementName=dataGrid}"/>
            </StackPanel>
        </Grid>
        <StackPanel  Grid.Row="1">
            <DataGrid x:Name="dataGrid" RowHeight="30"  Margin="5"
                     HorizontalAlignment="Stretch"
                     AutoGenerateColumns="False" CanUserAddRows="False"
                     SelectionUnit="FullRow" EnableColumnVirtualization="False"
                     GridLinesVisibility="None" Width="auto" Height="325"
                     SelectionMode="Extended" ItemsSource="{Binding Collection}">
                <DataGrid.Resources>
                    <Style x:Key="TextVerticalCenter" TargetType="{x:Type TextBlock}">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="名称" Width="180" SortMemberPath="Name" 
  Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
IsReadOnly="False" ElementStyle="{StaticResource TextVerticalCenter}"/>
                    <DataGridTextColumn Header="类型" Width="60" SortMemberPath="MaterialCategory" 
  Binding="{Binding MaterialCategory}" 
IsReadOnly="True" ElementStyle="{StaticResource TextVerticalCenter}"/>
                    <DataGridTemplateColumn Header="材质颜色" Width="80"
                             SortMemberPath="Name" >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button   Height="26"  BorderBrush="Transparent" 
      Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window},Path=DataContext.SetColorCommand}" CommandParameter="{Binding }" Background="{Binding Color,Converter={StaticResource colorConverter}}">
                                    <TextBlock Text="{Binding ColorValue}"   Foreground="{Binding Background, RelativeSource={RelativeSource AncestorType=Border}, Converter={StaticResource BackgroundToForegroundConverter}}" VerticalAlignment="Center"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="外观颜色">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="20" Height="20"
                Background="{Binding AppearanceColor, Converter={StaticResource colorConverter}}"
                BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="" Width="60" SortMemberPath="StatusText" 
  Binding="{Binding StatusText}" 
IsReadOnly="True" ElementStyle="{StaticResource TextVerticalCenter}"/>
                    <DataGridTemplateColumn Header="设置操作" CanUserResize="False" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="删除材质" Width="auto" Command="{Binding DataContext.DeleteElementCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
CommandParameter="{Binding }" Height="28" HorizontalAlignment="Stretch"
                    IsEnabled="{Binding IsUsed, Converter={StaticResource InverseBooleanConverter}}"     />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
        <DockPanel Grid.Row="2" >
            <Button  Content="确定并退出" Margin="5,0" FontSize="16" 
                     HorizontalAlignment="Stretch" Click="btn_OK_Click"/>
        </DockPanel>
    </Grid>
</Window>
