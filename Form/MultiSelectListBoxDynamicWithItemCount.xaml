<UserControl x:Class="CreatePipe.Form.MultiSelectListBoxDynamicWithItemCount"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CreatePipe.Form"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="200" Background="Beige">

    <UserControl.Resources>
        <Style x:Key="EnabledTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Background" Value="#E9E9E9" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="Background" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ListBox         
        x:Name="MultiSelectLsBox"  
        SnapsToDevicePixels="True"
        OverridesDefaultStyle="False"
        ScrollViewer.HorizontalScrollBarVisibility="Disabled"  
        ScrollViewer.VerticalScrollBarVisibility="Auto"
        ScrollViewer.CanContentScroll="True"
        IsSynchronizedWithCurrentItem="True">
        <!-- 【核心：强制每个Item占满一整行宽度，这样内部的 Grid 才能把数量推到最右侧】 -->
        <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
        </ListBox.ItemContainerStyle>

        <ListBox.ItemTemplate>
            <DataTemplate>
                <!-- 使用 Grid 将复选框放左边，数量放右边 -->
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <!-- 左侧占满剩余空间 -->
                        <ColumnDefinition Width="Auto" />
                        <!-- 右侧仅占用文字需要的宽度 -->
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0" 
                              Content="{Binding Title}"
                              IsChecked="{Binding Path=IsSelected, Mode=TwoWay}"
                              Click="CheckBox_Click" 
                              VerticalAlignment="Center" />

                    <!-- 统计展示 TextBlock 放最右侧 -->
                    <TextBlock Grid.Column="1" 
                               Text="{Binding CountDisplay}" 
                               Foreground="Gray"
                               Margin="10,0,5,0"
                               VerticalAlignment="Center" />
                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
