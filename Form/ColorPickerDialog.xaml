<Window x:Class="CreatePipe.Form.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择颜色" 
        Width="240" 
        Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Topmost="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <!-- 颜色预览 -->
        <Border Grid.Row="0" 
                CornerRadius="5" 
                BorderBrush="Gray" 
                BorderThickness="1"
                Background="{Binding PreviewColorBrush}"
                Height="60"/>

        <!-- RGB 滑块 -->
        <StackPanel Grid.Row="1" Margin="0,10">
            <TextBlock Text="红色 (R):"/>
            <Slider x:Name="RedSlider" 
                    Minimum="0" 
                    Maximum="255" 
                    Value="{Binding Red}"/>
            <TextBlock Text="{Binding Red, StringFormat='红色值: {0}'}"/>

            <TextBlock Text="绿色 (G):" Margin="0,10,0,0"/>
            <Slider x:Name="GreenSlider" 
                    Minimum="0" 
                    Maximum="255" 
                    Value="{Binding Green}"/>
            <TextBlock Text="{Binding Green, StringFormat='绿色值: {0}'}"/>

            <TextBlock Text="蓝色 (B):" Margin="0,10,0,0"/>
            <Slider x:Name="BlueSlider" 
                    Minimum="0" 
                    Maximum="255" 
                    Value="{Binding Blue}"/>
            <TextBlock Text="{Binding Blue, StringFormat='蓝色值: {0}'}"/>
        </StackPanel>

        <!-- 预设颜色 -->
        <ItemsControl Grid.Row="2" 
                      ItemsSource="{Binding PresetColors}"
                      Margin="0,15,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="8" Rows="3"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Width="25" 
                            Height="25" 
                            Margin="2"
                            Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.SelectPresetColorCommand}"
                            CommandParameter="{Binding}">
                        <Button.Background>
                            <SolidColorBrush Color="{Binding}"/>
                        </Button.Background>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Grid.Row="3"  Content="确定" 
                    Click="OKButton_Click"
                    IsDefault="True" Margin="5"/>
    </Grid>
</Window>
