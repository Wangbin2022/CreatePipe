<Window x:Class="CreatePipe.Form.ToggleVisibilityView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="快捷类型显隐" Width="360" ResizeMode="NoResize"
        SizeToContent="Height" MinHeight="80"
        xmlns:local="clr-namespace:CreatePipe.Form"
        xmlns:btn="clr-namespace:CreatePipe.Form">
    <Grid x:Name="MainGrid" Margin="0,10,0,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Button Grid.Column="0" Grid.Row="0" Margin="6"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" 
                BorderBrush="Black" BorderThickness="1" Height="80"  
                HorizontalAlignment="Stretch" 
                Command="{Binding TVCommand1}">
            <Button.Content>
                <TextBlock Text="{Binding TVCommandName1}" 
                  TextWrapping="Wrap" 
                  TextAlignment="Center"/>
            </Button.Content>
        </Button>
        <Button Grid.Column="1" Grid.Row="0" Margin="6"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" 
                BorderBrush="Black" BorderThickness="1" Height="80"  
                HorizontalAlignment="Stretch"                 
                Command="{Binding TVCommand2}">
            <Button.Content>
                <TextBlock Text="{Binding TVCommandName2}" 
                  TextWrapping="Wrap" 
                  TextAlignment="Center"/>
            </Button.Content>
        </Button>
        <Button Grid.Column="2" Grid.Row="0" Margin="6"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" 
                BorderBrush="Black" BorderThickness="1" Height="80"  
                HorizontalAlignment="Stretch" 
                Command="{Binding TVCommand3}">
            <Button.Content>
                <TextBlock Text="{Binding TVCommandName3}" 
                  TextWrapping="Wrap" 
                  TextAlignment="Center"/>
            </Button.Content>
        </Button>
        <btn:CircleImageButton Grid.Column="3" Grid.Row="0" 
                               Margin="0,6,0,0"
                               Width="20" Height="20"
                               Background="White" 
                               BorderBrush="Black"
                               BorderThickness="1"
                               VerticalAlignment="Top"
                               ImageSource="pack://application:,,,/CreatePipe;component/Resources/plus16.png"
                               Click="BtnAddRow_Click">
        </btn:CircleImageButton>
        <Button Grid.Column="0" Grid.Row="1" Margin="6"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" 
                BorderBrush="Black" BorderThickness="1" Height="80"  
                HorizontalAlignment="Stretch" 
                Command="{Binding TVCommand4}">
            <Button.Content>
                <TextBlock Text="{Binding TVCommandName4}" 
                  TextWrapping="Wrap" 
                  TextAlignment="Center"/>
            </Button.Content>
        </Button>
        <Button Grid.Column="1" Grid.Row="1" Margin="6"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" 
                BorderBrush="Black" BorderThickness="1" Height="80"  
                HorizontalAlignment="Stretch" 
                Command="{Binding TVCommand5}">
            <Button.Content>
                <TextBlock Text="{Binding TVCommandName5}" 
                  TextWrapping="Wrap" 
                  TextAlignment="Center"/>
            </Button.Content>
        </Button>
        <Button Grid.Column="2" Grid.Row="1" Margin="6"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" 
                BorderBrush="Black" BorderThickness="1" Height="80"  
                HorizontalAlignment="Stretch"
                Command="{Binding TVCommand6}">
            <Button.Content>
                <TextBlock Text="{Binding TVCommandName6}" 
                  TextWrapping="Wrap" 
                  TextAlignment="Center"/>
            </Button.Content>
        </Button>
        <btn:CircleImageButton Grid.Column="3" Grid.Row="1" 
                               Width="20" Height="20"
                               Background="White" 
                               BorderBrush="Black"
                               BorderThickness="1"
                               VerticalAlignment="Center"
                               ImageSource="pack://application:,,,/CreatePipe;component/Resources/minus16.png"
                               Click="BtnRemoveRow_Click">
        </btn:CircleImageButton>
        <Button Grid.Column="0" Grid.Row="2" Margin="6"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" 
                BorderBrush="Black" BorderThickness="1" Height="80"  
                HorizontalAlignment="Stretch" 
                Command="{Binding TVCommand7}">
            <Button.Content>
                <TextBlock Text="{Binding TVCommandName7}" 
                   TextWrapping="Wrap" 
                   TextAlignment="Center"/>
            </Button.Content>
        </Button>
        <Button Grid.Column="1" Grid.Row="2" Margin="6"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" 
                BorderBrush="Black" BorderThickness="1" Height="80"  
                HorizontalAlignment="Stretch"
                Command="{Binding TVCommand8}">
            <Button.Content>
                <TextBlock Text="{Binding TVCommandName8}" 
                   TextWrapping="Wrap" 
                   TextAlignment="Center"/>
            </Button.Content>
        </Button>
        <Button Grid.Column="2" Grid.Row="2" Margin="6"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" 
                BorderBrush="Black" BorderThickness="1" Height="80"  
                HorizontalAlignment="Stretch" 
                Command="{Binding TVCommand9}">
            <Button.Content>
                <TextBlock Text="{Binding TVCommandName9}" 
                   TextWrapping="Wrap" 
                   TextAlignment="Center"/>
            </Button.Content>
        </Button>
    </Grid>
</Window>