<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:db="clr-namespace:CreatePipe.Form.UserControls">
    <!-- 隐式 DataGridCell 样式，应用于所有 DataGridCell -->
    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridCell}">
                    <Border BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <TextBlock TextAlignment="Center" VerticalAlignment="Center">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </TextBlock>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="LightGray"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="LightBlue"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- TextBlock 垂直居中样式 (带Key) -->
    <Style x:Key="TextVerticalCenter" TargetType="{x:Type TextBlock}">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style TargetType="{x:Type db:DrawerButton}">
        <Setter Property="Background" Value="#FF007ACC"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type db:DrawerButton}">
                    <Grid>
                        <!-- 按钮主体 -->
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <!-- 💡 修改点 1：将 PlacementTarget 绑定到它所在的 Window -->
                        <Popup x:Name="PART_Popup"
       IsOpen="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
       StaysOpen="False" 
       PlacementTarget="{Binding Path=Content, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
       Placement="Bottom"
       AllowsTransparency="True"
       PopupAnimation="Slide">
                            <!-- Slide 提供原生向下抽屉滑出动画 -->

                            <!-- 💡 修改点 2：将抽屉的宽度绑定为 Window 的宽度 (即 PlacementTarget 的宽度) -->
                            <Border Background="White"
                                    BorderThickness="1"
                                    BorderBrush="#E0E0E0"
                                    Width="{Binding PlacementTarget.ActualWidth, ElementName=PART_Popup}">
                                <!-- 承载用户自定义的抽屉内容 -->
                                <ContentPresenter Content="{TemplateBinding DrawerContent}"/>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- 鼠标悬停变色效果 -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#FF005A9E"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="MainBorder" Property="Background" Value="#FF004578"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>