<Window x:Class="CreatePipe.Form.ClipboardCatcher"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.Form"
        xmlns:uc="clr-namespace:CreatePipe.Form"
        xmlns:btn="clr-namespace:CreatePipe.Form"
        mc:Ignorable="d"
        Title="文本暂存助手" Width="360" ResizeMode="NoResize"
        Topmost="True" SizeToContent="Height" MinHeight="80">
    <Grid x:Name="MainGrid" Margin="0,10,0,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <uc:UniversialSplitButton  Grid.Column="0" Grid.Row="0" Margin="6"
        DataContext="{Binding Slot1}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0" Height="80"/>
        <uc:UniversialSplitButton  Grid.Column="1" Grid.Row="0" Margin="6"
        DataContext="{Binding Slot2}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
        <uc:UniversialSplitButton  Grid.Column="2" Grid.Row="0" Margin="6"
        DataContext="{Binding Slot3}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
        <btn:CircleImageButton Grid.Column="3" Grid.Row="0" 
                               Margin="0,6,0,0"
                               Width="20" Height="20"
                               Background="White" 
                               BorderBrush="Black"
                               BorderThickness="1"
                               VerticalAlignment="Top"
                               ImageSource="pack://application:,,,/CreatePipe;component/Resources/plus16.png"
                               Click="BtnAddRow_Click">
        </btn:CircleImageButton>
        <uc:UniversialSplitButton  Grid.Column="0" Grid.Row="1" Margin="6"
        DataContext="{Binding Slot4}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"  Height="80"/>
        <uc:UniversialSplitButton  Grid.Column="1" Grid.Row="1" Margin="6"
        DataContext="{Binding Slot5}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
        <uc:UniversialSplitButton  Grid.Column="2" Grid.Row="1" Margin="6"
        DataContext="{Binding Slot6}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
        <btn:CircleImageButton Grid.Column="3" Grid.Row="1" 
                               Width="20" Height="20"
                               Background="White" 
                               BorderBrush="Black"
                               BorderThickness="1"
                               VerticalAlignment="Center"
                               ImageSource="pack://application:,,,/CreatePipe;component/Resources/minus16.png"
                               Click="BtnRemoveRow_Click">
        </btn:CircleImageButton>
        <uc:UniversialSplitButton  Grid.Column="0" Grid.Row="2" Margin="6"
        DataContext="{Binding Slot7}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"  Height="80"/>
        <uc:UniversialSplitButton  Grid.Column="1" Grid.Row="2" Margin="6"
        DataContext="{Binding Slot8}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
        <uc:UniversialSplitButton  Grid.Column="2" Grid.Row="2" Margin="6"
        DataContext="{Binding Slot9}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
    </Grid>
</Window>
