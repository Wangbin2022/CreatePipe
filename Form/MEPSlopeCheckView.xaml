<Window x:Class="CreatePipe.Form.MEPSlopeCheckView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:uc="clr-namespace:CreatePipe.Form"
        xmlns:btn="clr-namespace:CreatePipe.Form"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converter"
        xmlns:form="clr-namespace:CreatePipe.Form"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="机电管线坡度检查" Width="240" Height="260"
        ResizeMode="NoResize" Topmost="True" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="TransparentHoverButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="SlateGray"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="CadetBlue"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" 
                       Text="检查范围" VerticalAlignment="Center"/>
            <form:MultiSelectComboBox  Grid.Row="0" Grid.Column="1" Margin="5"
                                       ItemsSource="{Binding Items}" 
                                       SelectedItems="{Binding SelectedItems}" 
                                       ToolTip="{Binding Path=Text, RelativeSource={RelativeSource Self}}" />
            <TextBlock Grid.Row="1" Grid.Column="0" 
                       Text="检查条件（附加条件）" VerticalAlignment="Center"/>
            <CheckBox Grid.Row="1" Grid.Column="1" 
                      x:Name="ChkOption" Content="" 
                      IsChecked="{Binding IsOptionChecked, Mode=TwoWay}"
                      HorizontalAlignment="Right" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="2" Grid.Column="0" 
                      VerticalAlignment="Center" 
                      SelectedIndex="0" 
                      SelectedItem="{Binding DefaultSymbol, Mode=TwoWay}"
                      Margin="0,5,5,5">
                <ComboBox.ItemsSource>
                    <x:Array Type="sys:String">
                        <sys:String>大于</sys:String>
                        <sys:String>小于</sys:String>
                        <sys:String>等于</sys:String>
                        <sys:String>不等于</sys:String>
                    </x:Array>
                </ComboBox.ItemsSource>
            </ComboBox>
            <ComboBox Grid.Row="2" Grid.Column="1" 
                      VerticalAlignment="Center" 
                      Visibility="{Binding IsChecked, ElementName=ChkOption, Converter={StaticResource BoolToVis}}"
                      SelectedIndex="0" 
                      SelectedItem="{Binding OptionSymbol, Mode=TwoWay}"
                      Margin="5">
                <ComboBox.ItemsSource>
                    <x:Array Type="sys:String">
                        <sys:String>大于</sys:String>
                        <sys:String>小于</sys:String>
                        <sys:String>等于</sys:String>
                        <sys:String>不等于</sys:String>
                    </x:Array>
                </ComboBox.ItemsSource>
            </ComboBox>
            <ComboBox Grid.Row="3" Grid.Column="0" 
                      VerticalAlignment="Center" 
                      SelectedIndex="0" IsEditable="True"
                      Text="{Binding DefaultNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Margin="0,5,5,5">
                <ComboBox.ItemsSource>
                    <x:Array Type="sys:String">
                        <sys:String>1%</sys:String>
                        <sys:String>2%</sys:String>
                        <sys:String>0度</sys:String>
                        <sys:String>90度</sys:String>
                    </x:Array>
                </ComboBox.ItemsSource>
            </ComboBox>
            <ComboBox Grid.Row="3" Grid.Column="1" 
                      VerticalAlignment="Center" 
                      Visibility="{Binding IsChecked, ElementName=ChkOption, Converter={StaticResource BoolToVis}}"
                      SelectedIndex="0"  IsEditable="True"
                      Text="{Binding OptionNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Margin="5">
                <ComboBox.ItemsSource>
                    <x:Array Type="sys:String">
                        <sys:String>1%</sys:String>
                        <sys:String>2%</sys:String>
                        <sys:String>0度</sys:String>
                        <sys:String>90度</sys:String>
                    </x:Array>
                </ComboBox.ItemsSource>
            </ComboBox>
            <!-- 新增：保存条件按钮 -->
            <Button Content="保存条件..." Grid.Row="4" Grid.Column="0" 
                    Style="{StaticResource TransparentHoverButtonStyle}"
                    Command="{Binding SaveConfigCommand}"  Margin="0,0,10,0"/>
            <!-- 新增：加载条件按钮 -->
            <Button Content="加载条件..." Grid.Row="4" Grid.Column="1" 
                    Style="{StaticResource TransparentHoverButtonStyle}"
                    Command="{Binding LoadConfigCommand}"  Margin="0,0,10,0"/>
        </Grid>
        <DockPanel Grid.Row="1" Margin="0,5,5,5">
            <Button  Content="查找并高亮显示" Command="{Binding DrawTableCommand}"
                     HorizontalAlignment="Stretch" Click="btn_OK_Click"/>
        </DockPanel>
    </Grid>
</Window>
