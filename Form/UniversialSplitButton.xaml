<UserControl x:Class="CreatePipe.Form.UniversialSplitButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CreatePipe.Form"
             xmlns:conv="clr-namespace:CreatePipe.Form.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="120"
             x:Name="splitButton">
    <UserControl.Resources>
        <!-- 按钮基础样式 -->
        <Style x:Key="ButtonPartStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{Binding CornerRadius, ElementName=splitButton}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding HoverColor, ElementName=splitButton}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{Binding PressedColor, ElementName=splitButton}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 分割线样式 -->
        <Style x:Key="DividerStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="0"/>
            <Setter Property="Fill" Value="{Binding DividerColor, ElementName=splitButton}"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- 主按钮区域 - 左半部分 -->
        <Button x:Name="MainButton" Grid.Column="0"
                Style="{StaticResource ButtonPartStyle}"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,0"
                Command="{Binding MainCommand, ElementName=splitButton}"
                CommandParameter="{Binding MainCommandParameter, ElementName=splitButton}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                    <!-- 主按钮内容区域 -->
                    <ContentControl Grid.Column="0" 
                Content="{Binding MainContent, ElementName=splitButton}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                    <ContentControl.Resources>
                        <conv:TextTruncateConverter x:Key="TextTruncateConverter"/>
                        <conv:IsStringConverter x:Key="IsStringConverter"/>
                    </ContentControl.Resources>
                    <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- 1. 默认显示：当作普通内容显示 (如果是图片，会直接显示图片) -->
                                    <ContentPresenter x:Name="DefaultPresenter" Content="{Binding}" />

                                    <!-- 2. 文本显示：专门用于处理文字截断的 TextBlock (默认隐藏) -->
                                    <TextBlock x:Name="TruncatedText" 
                           Text="{Binding Converter={StaticResource TextTruncateConverter}, ConverterParameter=5}"
                           Visibility="Collapsed" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center"/>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <!-- 【核心逻辑】：判断内容是不是字符串 -->
                                    <!-- 如果 Binding 的对象类型是 String，则显示截断的 TextBlock，隐藏原始 Presenter -->
                                    <DataTrigger Binding="{Binding Converter={StaticResource IsStringConverter}}" Value="True">
                                        <Setter TargetName="TruncatedText" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="DefaultPresenter" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                    <!-- 分割线 -->
                <Rectangle Grid.Column="1" 
                           Style="{StaticResource DividerStyle}"
                           Visibility="{Binding ShowDivider, ElementName=splitButton}"/>
            </Grid>
        </Button>
        <!-- 右侧小按钮区域 - 覆盖在右上四分之一位置 -->
        <Button x:Name="SecondaryButton" Grid.Column="1"
                Style="{StaticResource ButtonPartStyle}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" 
                Background="Transparent"
                Command="{Binding SecondaryCommand, ElementName=splitButton}"
                CommandParameter="{Binding SecondaryCommandParameter, ElementName=splitButton}">

            <ContentControl Content="{Binding SecondaryContent, ElementName=splitButton}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
        </Button>
    </Grid>
</UserControl>
