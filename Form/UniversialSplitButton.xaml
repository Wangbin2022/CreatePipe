<UserControl x:Class="CreatePipe.Form.UniversialSplitButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CreatePipe.Form"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="120"
             x:Name="splitButton">
    <UserControl.Resources>
        <!-- 按钮基础样式 -->
        <Style x:Key="ButtonPartStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{Binding CornerRadius, ElementName=splitButton}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding HoverColor, ElementName=splitButton}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{Binding PressedColor, ElementName=splitButton}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 分割线样式 -->
        <Style x:Key="DividerStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="0"/>
            <Setter Property="Fill" Value="{Binding DividerColor, ElementName=splitButton}"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- 主按钮区域 - 左半部分 -->
        <Button x:Name="MainButton" Grid.Column="0"
                Style="{StaticResource ButtonPartStyle}"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,0"
                Command="{Binding MainCommand, ElementName=splitButton}"
                CommandParameter="{Binding MainCommandParameter, ElementName=splitButton}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- 主按钮内容 -->
                <ContentControl Grid.Column="0" 
                                Content="{Binding MainContent, ElementName=splitButton}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                <!-- 分割线 -->
                <Rectangle Grid.Column="1" 
                           Style="{StaticResource DividerStyle}"
                           Visibility="{Binding ShowDivider, ElementName=splitButton}"/>
            </Grid>
        </Button>
        <!-- 右侧小按钮区域 - 覆盖在右上四分之一位置 -->
        <Button x:Name="SecondaryButton" Grid.Column="1"
                Style="{StaticResource ButtonPartStyle}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" 
                Background="Transparent"
                Command="{Binding SecondaryCommand, ElementName=splitButton}"
                CommandParameter="{Binding SecondaryCommandParameter, ElementName=splitButton}">

            <ContentControl Content="{Binding SecondaryContent, ElementName=splitButton}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
        </Button>
    </Grid>
</UserControl>
