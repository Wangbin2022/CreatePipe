<Window x:Class="CreatePipe.Form.StairsManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.Form"
        mc:Ignorable="d"
        Title="StairsManagerView" 
        Height="450" Width="720"  Topmost="True"
     WindowStartupLocation="Manual" Left="30" Top="210" ResizeMode="CanMinimize"
       xmlns:vc="clr-namespace:CreatePipe.Form.Converters"
       xmlns:bv="clr-namespace:CreatePipe.Form.Behaviors">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 引用你的 CommonDataGridStyles.xaml -->
                <ResourceDictionary Source="/CreatePipe;component/Form/ResourceDictionary/CommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="5">
        <Grid.Resources>
            <vc:IntToStringConverter x:Key="IntToStringConverter"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <Grid  >
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBox Width="230"  Margin="5"
bv:TextBoxBehavior.TextChangedCommand="{Binding QueryElementCommand}" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="{Binding Collection.Count,UpdateSourceTrigger=LostFocus,Converter={StaticResource IntToStringConverter}}" VerticalAlignment="Center"/>
                <!--<Button Content="删除楼梯扶手"  Width="80" Margin="5"  Command="{Binding DeleteElementCommand}"
    HorizontalAlignment="Right"/>-->
                <Button Width="80" Margin="5" Content="删除选中楼梯" Command="{Binding DeleteElementsCommand}"
                      CommandParameter="{Binding SelectedItems, ElementName=dataGrid}"/>
            </StackPanel>
        </Grid>
        <TabControl  Grid.Row="1" Margin="5" TabStripPlacement="Left">
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="梯段清单" 
                       Width="20" 
                       TextWrapping="Wrap" 
                       TextAlignment="Center" 
                       VerticalAlignment="Center" />
                </TabItem.Header>
                <DataGrid x:Name="dataGrid" RowHeight="30"  Margin="5"
              HorizontalAlignment="Stretch"
              AutoGenerateColumns="False" CanUserAddRows="False"
              SelectionUnit="FullRow" EnableColumnVirtualization="False"
              GridLinesVisibility="None" Width="auto" Height="325"
              SelectionMode="Extended" ItemsSource="{Binding Collection}">
                    <DataGrid.Resources>
                        <Style x:Key="TextVerticalCenter" TargetType="{x:Type TextBlock}">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                        <Style x:Key="TextVerticalArea" TargetType="{x:Type TextBlock}">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="编号" Binding="{Binding stairName, StringFormat={}{0:F1}}" Width="50" IsReadOnly="True" ElementStyle="{StaticResource TextVerticalCenter}" SortMemberPath="stairName" />
                        <DataGridTextColumn Header="起点高程" Binding="{Binding startLevelHeight, StringFormat={}{0:F0}}" Width="60" IsReadOnly="True" ElementStyle="{StaticResource TextVerticalCenter}" SortMemberPath="startLevelHeight" />
                        <DataGridTextColumn Header="梯段高度" Binding="{Binding stairTotalHeight, StringFormat={}{0:F0}}" Width="80" IsReadOnly="True" ElementStyle="{StaticResource TextVerticalCenter}" SortMemberPath="stairTotalHeight" />
                        <DataGridTextColumn Header="踏步数" Binding="{Binding ActualHorizontalSteps }" Width="50" IsReadOnly="True" ElementStyle="{StaticResource TextVerticalCenter}" SortMemberPath="ActualHorizontalSteps" />
                        <DataGridTextColumn Header="踢步数" Binding="{Binding ActualVerticalSteps }" Width="50" IsReadOnly="True" ElementStyle="{StaticResource TextVerticalCenter}" SortMemberPath="ActualVerticalSteps" />
                        <DataGridTextColumn Header="单步深" Binding="{Binding stepWidth, StringFormat={}{0:F1}}" Width="50" IsReadOnly="True" ElementStyle="{StaticResource TextVerticalCenter}" SortMemberPath="stepWidth" />
                        <DataGridTextColumn Header="单步高" Binding="{Binding stepHeight, StringFormat={}{0:F1}}" Width="50" IsReadOnly="True" ElementStyle="{StaticResource TextVerticalCenter}" SortMemberPath="stepHeight" />
                        <DataGridTextColumn Header="梯段宽" Binding="{Binding stairRunWidth, StringFormat={}{0:F1}}" Width="50" IsReadOnly="True" ElementStyle="{StaticResource TextVerticalCenter}" SortMemberPath="stairRunWidth" />
                        <DataGridTemplateColumn Header="有报错" Width="50"
SortMemberPath="HasWarnings" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <!-- 1. 设置默认值：假设默认是有样板 -->
                                                <Setter Property="Text" Value="无" />
                                                <Setter Property="Foreground" Value="Red" />
                                                <Style.Triggers>
                                                    <!-- 2. 只有当确实为 False 时，才切换到红色和“无” -->
                                                    <DataTrigger Binding="{Binding HasWarnings}" Value="False">
                                                        <Setter Property="Text" Value="无" />
                                                        <Setter Property="Foreground" Value="Green" />
                                                    </DataTrigger>
                                                    <!-- 3. 增加一个保险：显式处理 True -->
                                                    <DataTrigger Binding="{Binding HasWarnings}" Value="True">
                                                        <Setter Property="Text" Value="有" />
                                                        <Setter Property="Foreground" Value="Red" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="选择楼梯" CanUserResize="False" Width="75">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Id}" Width="70" Command="{Binding DataContext.PickElementCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
CommandParameter="{Binding }" Height="28" HorizontalAlignment="Stretch"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="梯段组合" 
             Width="20" 
             TextWrapping="Wrap" 
             TextAlignment="Center" 
             VerticalAlignment="Center" />
                </TabItem.Header>
                <DataGrid RowHeight="30"  Margin="5"
              HorizontalAlignment="Stretch"
              AutoGenerateColumns="False" CanUserAddRows="False"
              SelectionUnit="FullRow" EnableColumnVirtualization="False"
              GridLinesVisibility="None" Width="auto" Height="325"
              SelectionMode="Extended" ItemsSource="{Binding CollectionStairGroup}">
                    <DataGrid.Resources>
                        <Style x:Key="TextVerticalCenter" TargetType="{x:Type TextBlock}">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                        <Style x:Key="TextVerticalArea" TargetType="{x:Type TextBlock}">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="楼梯编号" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"  Width="66" IsReadOnly="False" ElementStyle="{StaticResource TextVerticalCenter}" SortMemberPath="Name" />
                        <DataGridTextColumn Header="构件数"   Binding="{Binding SelectedStairs.Count}" 
                          Width="50"  IsReadOnly="True"  ElementStyle="{StaticResource TextVerticalCenter}" />
                        <DataGridTemplateColumn Header="统计" CanUserResize="False" Width="66">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="梯段" Width="60" Command="{Binding DataContext.SubViewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
CommandParameter="{Binding .}" Height="28" HorizontalAlignment="Stretch"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="三维生成" CanUserResize="False" Width="85">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="生成" Width="80" Command="{Binding DataContext.NewSectionBoxViewCommand, RelativeSource={RelativeSource AncestorType=Window}}"
CommandParameter="{Binding .}" Height="28" HorizontalAlignment="Stretch"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
        <DockPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="5">
            <Button  Content="确定并退出" Height="auto" FontSize="16"
                     HorizontalAlignment="Stretch" Click="btn_OK_Click"/>
        </DockPanel>
    </Grid>
</Window>
