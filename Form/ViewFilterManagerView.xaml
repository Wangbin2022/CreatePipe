<Window x:Class="CreatePipe.Form.ViewFilterManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.Form"
        mc:Ignorable="d" 
        Title="过滤器管理" Height="450" Width="720"
               Topmost="True"
       WindowStartupLocation="Manual" Left="30" Top="300" ResizeMode="CanMinimize"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters"
       xmlns:bv="clr-namespace:CreatePipe.Form.Behaviors"
       xmlns:uc="clr-namespace:CreatePipe.Form"
        xmlns:helper="clr-namespace:CreatePipe.Utils">
    <Grid Margin="10">
        <Grid.Resources>
            <conv:ColorConverter x:Key="ColorConverter"/>
            <conv:IntToStringConverter x:Key="IntToStringConverter"/>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3.2*"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBox Width="230"  Margin="0,5"
bv:TextBoxBehavior.TextChangedCommand="{Binding QueryElementCommand}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding Collection.Count,UpdateSourceTrigger=PropertyChanged,Converter={StaticResource IntToStringConverter}}" VerticalAlignment="Center"/>
                <Button Content="删除过滤器" Width="80" Margin="2,4"
                  Command="{Binding DeleteElementsCommand}"
                  CommandParameter="{Binding SelectedItems, ElementName=dataGrid}"
                  HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>
        <Grid  Grid.Row="1" Margin="0,5">
            <DataGrid x:Name="dataGrid" RowHeight="28"  
             HorizontalAlignment="Stretch"  
             AutoGenerateColumns="False" CanUserAddRows="False"
             SelectionUnit="FullRow" EnableColumnVirtualization="False"
             GridLinesVisibility="None" Height="auto"  Width="auto"
             SelectionMode="Extended" ItemsSource="{Binding Collection}"                          
                     helper:DataGridSelectionHelper.IsEnabled="True"
                  helper:DataGridSelectionHelper.SelectedItem="{Binding SelectedFilter, Mode=TwoWay}"
                  helper:DataGridSelectionHelper.SelectedItemsCount="{Binding RowCount, Mode=TwoWay}">
                <DataGrid.Resources>
                    <Style TargetType="DataGridCell" x:Key="dataGridCellStyle">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="LightGray"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Lightblue"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <TextBlock TextAlignment="Center" >
    <ContentPresenter />
                                    </TextBlock>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="TextVerticalCenter" TargetType="{x:Type TextBlock}">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.CellStyle>
                    <StaticResource ResourceKey="dataGridCellStyle"/>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="过滤器名称" Width="60" SortMemberPath="ViewFilterName" 
                 Binding="{Binding ViewFilterName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                    IsReadOnly="False" >
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding ViewFilterName}" />
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="在用" Width="35"
                                        SortMemberPath="IsInUsing" >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" >
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path= IsInUsing}" Value="False">
                                                    <Setter Property="Text"  Value="否">
                                                    </Setter>
                                                    <Setter Property="Foreground" Value="Red">
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Path= IsInUsing}" Value="True">
                                                    <Setter Property="Text"  Value="是">
                                                    </Setter>
                                                    <Setter Property="Foreground" Value="Green">
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="查找">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="查找" Width="60" ToolTip="查找在哪些视图应用了该过滤器"
                                        Command="{Binding DataContext.HideInViewCommand,                                        RelativeSource={RelativeSource AncestorType=Window}}" 
                                        CommandParameter="{Binding }" IsEnabled="{Binding IsHideBtn}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="和/或" Width="40"  SortMemberPath="ruleCombineType" 
                Binding="{Binding ruleCombineType}"  ElementStyle="{StaticResource TextVerticalCenter}"
                   IsReadOnly="True" />
                    <DataGridTextColumn Header="过滤规则" Width="110" SortMemberPath="ruleCombine" 
                Binding="{Binding ruleCombine}"
                   IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding ruleCombine}" />
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="材质颜色" Width="80"
                     SortMemberPath="Name" >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button  BorderBrush="Transparent"  Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window},Path=DataContext.SetColorCommand}" CommandParameter = "{Binding }" Background="{Binding Color,Converter={StaticResource ColorConverter}}">
                                    <TextBlock Text="{Binding ColorValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="Black"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="透明度" Width="45">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <ComboBox ItemsSource="{Binding TransparencySamples}"   SelectedValue="{Binding TransparencyNum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  VerticalContentAlignment="Center" Height="28" IsEditable="False"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="移除">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="清除应用" Width="60"  ToolTip="在所有视图删除该过滤器"
                                        Command="{Binding DataContext.ApplyToViewsCommand,                                        RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding }"  
                                         IsEnabled="{Binding IsHideBtn}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>  
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <TextBlock Grid.Column="1"  Margin="8"
                   Text="{Binding RowCount, StringFormat='选过滤器数量: {0}'}" VerticalAlignment="Center"/>
        <Grid Grid.Column="1" Grid.Row="1">
            <StackPanel Margin="5">
                <ListBox Height="85" x:Name="lsBox_Categorys" 
                        ItemsSource="{Binding SelectedFilter.CategoryItems}"  
                        IsEnabled="{Binding EnableCategoryList}"/>
                <TextBlock  Text="将选定过滤器复制到：" Height="25"/>
                <uc:MultiSelectListBox Height="177"
                                       IsEnabled="{Binding EnableCategoryList}"  
                    ItemsSource="{Binding SelectedFilter.CategoryItems}" 
                                       SelectedItems="{Binding SelectedListBoxItems}"/>
                <Button x:Name="btn_Paste" Height="25"
                        Content="复制到所有指定视图" 
                        IsEnabled="{Binding EnableCategoryList}"  
                        Command="{Binding SelectViewCommand}"
                        CommandParameter="{Binding SelectedListBoxItems}"/>
            </StackPanel>
        </Grid>
        <DockPanel Grid.Row="2" Grid.ColumnSpan="2">
            <Button  Content="完成修改并退出"  x:Name="btn_OK" FontSize="16"
                     HorizontalAlignment="Stretch" Click="btn_OK_Click"/>
        </DockPanel>
    </Grid>
</Window>

