<Window x:Class="CreatePipe.Universal369Buttons"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CreatePipe"
        Title="文本暂存器" 
        Height="Auto" Width="Auto"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="{Binding IsTopmost}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- 简单的按钮样式 -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="WhiteSmoke"/>
        </Style>
    </Window.Resources>

    <!-- 主容器，带圆角和阴影 -->
    <Border CornerRadius="10" Background="White" BorderBrush="LightGray" BorderThickness="1" Padding="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="10" ShadowDepth="2"/>
        </Border.Effect>

        <StackPanel>
            <!-- 标题栏区域（用于拖动） -->
            <Grid Margin="0,0,0,5">
                <TextBlock Text="功能面板" FontWeight="Bold" VerticalAlignment="Center"/>
                <!-- 关闭按钮 -->
                <Button Content="X" HorizontalAlignment="Right" Width="25" Height="20" 
                        Padding="0" Margin="0" Click="BtnClose_Click" FontSize="10"/>
            </Grid>

            <!-- 按钮容器：使用 ItemsControl 生成按钮 -->
            <ItemsControl ItemsSource="{Binding ButtonItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- 每3个换行 -->
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- 绑定 Visibility 属性 -->
                        <Button Content="{Binding Name}" 
                                Visibility="{Binding Visibility}"
                                Command="{Binding DataContext.SwitchCountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding Index}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 底部切换按钮 -->
            <Button Content="切换数量 (3/6/9)" Command="{Binding SwitchCountCommand}" 
                    Margin="5,10,5,0" Background="LightBlue"/>
        </StackPanel>
    </Border>
</Window>
