<Window x:Class="CreatePipe.Universal369Buttons"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CreatePipe"
        xmlns:uc="clr-namespace:CreatePipe.Form"
        xmlns:btn="clr-namespace:CreatePipe.Form"
        Title="文本暂存器" Width="360" ResizeMode="NoResize"
        SizeToContent="Height" MinHeight="80">
    <Grid x:Name="MainGrid" Margin="0,10,0,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <uc:UniversialSplitButton  Grid.Column="0" Grid.Row="0" Margin="6"
                                   Height="80"
                                   BorderBrush="Black" BorderThickness="1" CornerRadius="10"
                                   HoverColor="#E0E0E0" PressedColor="#C0C0C0"
                                   MainCommand="{Binding SaveCommand}"
                                   SecondaryCommand="{Binding TestCommand}" SecondaryContent="CR"
                                   ToolTip="非相同标高水平管垂直连接">
            <uc:UniversialSplitButton.MainContent>
                <Image Width="75" Height="75" Margin="0,0,5,0">
                    <Image.Source>
                        <BitmapImage DecodePixelWidth="75" 
                    UriSource="pack://application:,,,/CreatePipe;component/Resources/refresh32.png"/>
                    </Image.Source>
                </Image>
            </uc:UniversialSplitButton.MainContent>
        </uc:UniversialSplitButton>
        <!--<Button Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" 
                BorderBrush="Black" BorderThickness="1" Height="80" Margin="6"
                HorizontalAlignment="Stretch"
                Command="{Binding SaveCommand}">
            <Image Source="pack://application:,,,/CreatePipe;component/Resources/refresh32.png" Width="75"/>
        </Button>-->
        <!--<uc:UniversialSplitButton  Grid.Column="0" Grid.Row="0" Margin="6"
        DataContext="{Binding Slot1}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0" Height="80"/>-->
        <uc:UniversialSplitButton  Grid.Column="1" Grid.Row="0" Margin="6"
        DataContext="{Binding Slot2}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
        <uc:UniversialSplitButton  Grid.Column="2" Grid.Row="0" Margin="6"
        DataContext="{Binding Slot3}"
        MainContent="{Binding MainContent}" MainCommand="{Binding MainActionCommand}"
        SecondaryCommand="{Binding ClearActionCommand}" SecondaryContent="CR"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
        <btn:CircleImageButton Grid.Column="3" Grid.Row="0" 
                               Margin="0,6,0,0"
                               Width="20" Height="20"
                               Background="White" 
                               BorderBrush="Black"
                               BorderThickness="1"
                               VerticalAlignment="Top"
                               ImageSource="pack://application:,,,/CreatePipe;component/Resources/plus16.png"
                               Click="BtnAddRow_Click">
        </btn:CircleImageButton>
        <uc:UniversialSplitButton  Grid.Column="0" Grid.Row="1" Margin="6"
                          MainContent="保存"
                          SecondaryContent="C"
                          MainCommand="{Binding SaveCommand}"
                          SecondaryCommand="{Binding SaveOptionsCommand}"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0" Height="80"/>
        <uc:UniversialSplitButton  Grid.Column="1" Grid.Row="1" Margin="6"
                          MainContent="保存"
                          SecondaryContent="C"
                          MainCommand="{Binding SaveCommand}"
                          SecondaryCommand="{Binding SaveOptionsCommand}"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
        <uc:UniversialSplitButton  Grid.Column="2" Grid.Row="1" Margin="6"
                          MainContent="保存"
                          SecondaryContent="C"
                          MainCommand="{Binding SaveCommand}"
                          SecondaryCommand="{Binding SaveOptionsCommand}"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
        <btn:CircleImageButton Grid.Column="3" Grid.Row="1" 
                               Width="20" Height="20"
                               Background="White" 
                               BorderBrush="Black"
                               BorderThickness="1"
                               VerticalAlignment="Center"
                               ImageSource="pack://application:,,,/CreatePipe;component/Resources/minus16.png"
                               Click="BtnRemoveRow_Click">
        </btn:CircleImageButton>
        <uc:UniversialSplitButton  Grid.Column="0" Grid.Row="2" Margin="6"
                          MainContent="保存"
                          SecondaryContent="C"
                          MainCommand="{Binding SaveCommand}"
                          SecondaryCommand="{Binding SaveOptionsCommand}"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0" Height="80"/>
        <uc:UniversialSplitButton  Grid.Column="1" Grid.Row="2" Margin="6"
                          MainContent="保存"
                          SecondaryContent="C"
                          MainCommand="{Binding SaveCommand}"
                          SecondaryCommand="{Binding SaveOptionsCommand}"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
        <uc:UniversialSplitButton  Grid.Column="2" Grid.Row="2" Margin="6"
                          MainContent="保存"
                          SecondaryContent="C"
                          MainCommand="{Binding SaveCommand}"
                          SecondaryCommand="{Binding SaveOptionsCommand}"
                          HoverColor="#E0E0E0"
                          PressedColor="#C0C0C0"/>
    </Grid>
