<Window x:Class="CreatePipe.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:uc="clr-namespace:CreatePipe.Form"
        xmlns:btn="clr-namespace:CreatePipe.Form"
        xmlns:conv="clr-namespace:CreatePipe.Form.Converters"
        xmlns:form="clr-namespace:CreatePipe.Form"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="机电管线坡度检查" Width="240" Height="360"
        ResizeMode="NoResize" Topmost="True" WindowStartupLocation="CenterScreen"
        xmlns:bv="clr-namespace:CreatePipe.Form.Behaviors"
        xmlns:db="clr-namespace:CreatePipe.Form.UserControls">
    <Window.Resources>
        <!--<BooleanToVisibilityConverter x:Key="BoolToVis"/>-->
        <!--<Style x:Key="TransparentHoverButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="SlateGray"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="CadetBlue"/>
                </Trigger>
            </Style.Triggers>
        </Style>-->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 引用你的 CommonDataGridStyles.xaml -->
                <ResourceDictionary Source="/CreatePipe;component/Form/ResourceDictionary/CommonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
        </Grid>
        <StackPanel Margin="10">
            <TextBlock Text="只能输入整数（正数）："/>
            <TextBox bv:NumericInputBehavior.IsNumericEnabled="True"
                         Text="{Binding D, UpdateSourceTrigger=PropertyChanged}"
                         Height="30" Margin="0,5"/>
            <TextBlock Text="{Binding IntegerValue, StringFormat='当前值: {0}'}" 
                           Foreground="Gray"/>
        </StackPanel>

        <db:DrawerButton Content="点击展开抽屉菜单" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Top" 
                            Grid.Row="2">

            <!-- 定义抽屉里面显示的内容 (支持任意复杂布局) -->
            <db:DrawerButton.DrawerContent>
                <StackPanel Width="auto">
                    <TextBlock Text="新建任务参数" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                    <TextBlock Text="任务名称:" Margin="0,0,0,5"/>
                    <TextBox Margin="0,0,0,15" Padding="4"/>

                    <TextBlock Text="选择执行层:" Margin="0,0,0,5"/>
                    <ComboBox Margin="0,0,0,15">
                        <ComboBoxItem Content="结构层"/>
                        <ComboBoxItem Content="建筑层"/>
                    </ComboBox>

                    <Button Content="确认执行" Background="#FF28A745" Foreground="White" Padding="0,5"/>
                </StackPanel>
            </db:DrawerButton.DrawerContent>

        </db:DrawerButton>

        <!--<DockPanel Grid.Row="2" Margin="0,5,5,5">
            <Button  Content="查找并高亮显示" Command="{Binding DrawTableCommand}"
                     HorizontalAlignment="Stretch" Click="btn_OK_Click"/>
        </DockPanel>-->
    </Grid>
</Window>

