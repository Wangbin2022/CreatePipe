<Window x:Class="CreatePipe.Utils.ProgressBarDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreatePipe.Utils"
        mc:Ignorable="d" Left="70" Top="70"
        Title="ProgressBarDialog" Height="100" Width="500" 
        WindowStartupLocation="Manual"  Topmost="True"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True">
    <Border Background="#CC222222" CornerRadius="10" Padding="20">
        <StackPanel VerticalAlignment="Center">
            <ProgressBar Height="10" Maximum="{Binding Maximum}" Value="{Binding Value}"/>
            <TextBlock Text="{Binding Title}" FontWeight="Black" 
                       HorizontalAlignment="Center" Margin="20" Foreground="White"/>
        </StackPanel>
    </Border>
</Window>
